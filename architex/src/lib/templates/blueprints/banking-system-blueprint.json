  "rationale": {
    "decisions": [
      { "title": "Event Sourcing for Transactions", "context": "Financial transactions require complete audit trail and ability to reconstruct state at any point in time.", "decision": "Implement event sourcing with an append-only event store alongside the materialized ledger view.", "consequences": ["Complete audit trail for regulatory compliance", "Ability to replay events for reconciliation", "Higher storage costs for dual-write pattern", "Increased complexity in maintaining consistency"] },
      { "title": "Synchronous Fraud Check", "context": "Fraud detection must happen before transaction approval to prevent financial loss.", "decision": "Inline synchronous fraud scoring for all transactions with circuit breaker for degraded mode.", "consequences": ["Every transaction incurs ~20ms fraud check latency", "Circuit breaker allows low-risk transactions through during fraud engine issues", "High-risk transactions are never auto-approved"] },
      { "title": "Synchronous Replication for Ledger", "context": "Financial data cannot tolerate any data loss, even during database failover.", "decision": "Use synchronous replication between primary and standby ledger databases.", "consequences": ["Zero data loss guarantee (RPO=0)", "Slightly higher write latency due to sync commit", "Failover takes 15-30s instead of near-instant"] }
    ],
    "tradeoffs": [
      { "dimension": "Consistency vs Latency", "choice": "Consistency", "benefit": "Serializable transactions ensure no double-spend or overdraft", "cost": "Higher latency per transaction due to row-level locking" },
      { "dimension": "Security vs Usability", "choice": "Security", "benefit": "mTLS, encryption at rest, field-level encryption for PII", "cost": "More complex deployment, higher operational overhead" },
      { "dimension": "Cost vs Durability", "choice": "Durability", "benefit": "7-year event retention, 10-year audit log", "cost": "Significant storage costs for regulatory compliance" }
    ],
    "alternatives": [
      { "name": "CQRS Without Event Sourcing", "description": "Separate read and write models without maintaining full event history", "prosVsCons": "Pros: simpler implementation. Cons: no replay capability, weaker audit trail", "whyNotChosen": "Regulatory requirements mandate complete transaction history and reconstruction capability" },
      { "name": "Async Fraud Detection", "description": "Check fraud asynchronously and reverse fraudulent transactions after the fact", "prosVsCons": "Pros: lower latency. Cons: financial exposure during detection window, poor user experience for reversals", "whyNotChosen": "Unacceptable financial risk and regulatory non-compliance" }
    ]
  }
}
