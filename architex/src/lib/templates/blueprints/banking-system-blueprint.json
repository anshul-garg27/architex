  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-ledger-corruption",
        "name": "Ledger Database Failover",
        "description": "Primary ledger database crashes, triggering automatic failover to synchronous replica",
        "targetNodes": ["ledger-db"],
        "faultType": "crash",
        "severity": 5,
        "expectedBehavior": "Transactions pause for 15-30s during failover. No data loss due to synchronous replication. Event store provides audit trail for recovery verification.",
        "mitigationSteps": ["Automatic failover to synchronous standby", "Verify ledger consistency via event store replay", "Resume transaction processing", "Post-incident reconciliation check"]
      },
      {
        "id": "cs-fraud-latency",
        "name": "Fraud Engine Latency Spike",
        "description": "ML model inference latency spikes to 500ms due to resource contention",
        "targetNodes": ["fraud-engine"],
        "faultType": "latency",
        "severity": 3,
        "expectedBehavior": "Transaction approval latency increases. Circuit breaker opens after timeout. Transactions below risk threshold auto-approved; high-risk transactions queued.",
        "mitigationSteps": ["Circuit breaker bypasses fraud check for low-risk transactions", "Queue high-risk transactions for async review", "Scale fraud engine horizontally", "Investigate model inference bottleneck"]
      },
      {
        "id": "cs-kafka-partition",
        "name": "Event Bus Partition",
        "description": "Kafka cluster experiences network partition between brokers",
        "targetNodes": ["event-bus"],
        "faultType": "partition",
        "severity": 4,
        "expectedBehavior": "Event publishing delays. Notifications and compliance checks delayed. Core transaction processing continues as event publishing is async.",
        "mitigationSteps": ["Kafka controller triggers leader re-election", "Producers retry with idempotency keys", "Consumers resume from last committed offset", "Verify no duplicate processing"]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 5000,
        "bottleneckNode": "ledger-db",
        "metric": "connections",
        "description": "Ledger DB connection pool saturates due to long-running transactions with row-level locking",
        "resolution": "Implement connection pooling with PgBouncer, optimize transaction scope"
      },
      {
        "rpsThreshold": 10000,
        "bottleneckNode": "fraud-engine",
        "metric": "cpu",
        "description": "ML model inference becomes CPU-bound, increasing transaction latency",
        "resolution": "Add GPU instances for inference, implement model batching"
      },
      {
        "rpsThreshold": 25000,
        "bottleneckNode": "event-bus",
        "metric": "queue-depth",
        "description": "Kafka consumer lag grows, delaying notifications and compliance checks",
        "resolution": "Add consumer instances, increase partition count"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-double-spend",
        "title": "Double-Spend Race Condition",
        "description": "Concurrent transfers from same account could overdraw if balance check and debit are not atomic",
        "affectedNodes": ["transaction-service", "ledger-db"],
        "likelihood": 3,
        "impact": 5,
        "mitigation": "Serializable isolation level for transfers, pessimistic locking on account balance row"
      },
      {
        "id": "ei-reconciliation-drift",
        "title": "Ledger Reconciliation Drift",
        "description": "Running balances may drift from event-sourced balances over time due to rounding or failed compensating transactions",
        "affectedNodes": ["ledger-db", "event-store"],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Nightly reconciliation job comparing ledger state with event replay, alerting on any discrepancy"
      },
      {
        "id": "ei-compliance-backlog",
        "title": "AML Processing Backlog",
        "description": "Compliance service falls behind during peak hours, delaying suspicious activity reports",
        "affectedNodes": ["compliance-service", "event-bus"],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Priority queue for high-risk transactions, auto-scaling compliance workers, batch processing for low-risk"
      }
    ],
