        { "incident": "Fraud engine latency spike", "severity": "high", "steps": ["Activate low-risk auto-approve circuit breaker", "Queue high-risk transactions", "Scale GPU instances", "Investigate model inference bottleneck"], "automatedRecovery": true },
        { "incident": "Suspected data breach", "severity": "critical", "steps": ["Activate incident response team", "Isolate affected services", "Rotate credentials and tokens", "Notify regulatory bodies within 72h", "Forensic analysis"], "automatedRecovery": false }
