    { "id": "ap-lb", "type": "load-balancer", "position": { "x": 700, "y": 150 }, "data": { "label": "AP-Southeast LB", "category": "load-balancing", "componentType": "load-balancer-l7", "icon": "GitBranch", "config": { "region": "ap-southeast-1", "algorithm": "least-connections" }, "state": "idle" } },
    { "id": "us-app", "type": "web-server", "position": { "x": 100, "y": 300 }, "data": { "label": "US App Servers", "category": "compute", "componentType": "web-server", "icon": "Server", "config": { "instances": 10, "region": "us-east-1", "processingTimeMs": 20 }, "state": "idle" } },
    { "id": "eu-app", "type": "web-server", "position": { "x": 400, "y": 300 }, "data": { "label": "EU App Servers", "category": "compute", "componentType": "web-server", "icon": "Server", "config": { "instances": 8, "region": "eu-west-1", "processingTimeMs": 20 }, "state": "idle" } },
    { "id": "ap-app", "type": "web-server", "position": { "x": 700, "y": 300 }, "data": { "label": "AP App Servers", "category": "compute", "componentType": "web-server", "icon": "Server", "config": { "instances": 6, "region": "ap-southeast-1", "processingTimeMs": 20 }, "state": "idle" } },
