    { "id": "eu-db", "type": "database", "position": { "x": 400, "y": 450 }, "data": { "label": "EU CockroachDB", "category": "storage", "componentType": "postgresql", "icon": "Database", "config": { "type": "cockroachdb", "nodes": 5, "region": "eu-west-1", "storageGB": 2000 }, "state": "idle" } },
    { "id": "ap-db", "type": "database", "position": { "x": 700, "y": 450 }, "data": { "label": "AP CockroachDB", "category": "storage", "componentType": "postgresql", "icon": "Database", "config": { "type": "cockroachdb", "nodes": 3, "region": "ap-southeast-1", "storageGB": 1000 }, "state": "idle" } },
    { "id": "global-cache", "type": "cache", "position": { "x": 400, "y": 600 }, "data": { "label": "Global Redis (ElastiCache)", "category": "storage", "componentType": "redis", "icon": "Zap", "config": { "type": "redis", "globalDatastore": true, "regions": 3, "memoryGB": 64 }, "state": "idle" } },
    { "id": "conflict-resolver", "type": "web-server", "position": { "x": 100, "y": 600 }, "data": { "label": "Conflict Resolver", "category": "compute", "componentType": "web-server", "icon": "GitMerge", "config": { "instances": 3, "strategy": "last-writer-wins", "crdtEnabled": true }, "state": "idle" } },
