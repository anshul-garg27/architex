        { "level": 3, "name": "VP Engineering", "responseTimeMinutes": 30, "contacts": ["vp-eng"] }
      ],
      "runbooks": [
        { "incident": "Event store failure", "severity": "critical", "steps": ["Verify EventStoreDB cluster status", "Events buffered in Kafka for durability", "Commands return 503 until recovery", "Replay buffered events post-recovery", "Verify event sequence integrity"], "automatedRecovery": true },
        { "incident": "Stuck sagas", "severity": "high", "steps": ["Identify stuck saga instances", "Check dependent service health", "Force-complete or compensate stuck sagas", "Investigate root cause", "Adjust saga timeout if needed"], "automatedRecovery": false },
        { "incident": "DLQ overflow", "severity": "medium", "steps": ["Analyze DLQ message patterns", "Fix consumer bug causing failures", "Replay DLQ messages", "Monitor for regression"], "automatedRecovery": false }
      ]
    }
  },
  "rationale": {
    "decisions": [
      { "title": "CQRS (Command Query Responsibility Segregation)", "context": "Read and write patterns differ significantly. Writes need strong consistency; reads need speed.", "decision": "Separate command (write) and query (read) models with event projections maintaining the read side.", "consequences": ["Optimized read model for queries", "Independent scaling of read and write paths", "Eventual consistency between write and read", "Additional complexity of maintaining projections"] },
      { "title": "Orchestration-Based Sagas", "context": "Multi-service transactions require coordination. Choreography-based sagas are hard to reason about.", "decision": "Use a centralized saga orchestrator that manages the workflow steps.", "consequences": ["Clear workflow visibility and debugging", "Centralized compensation logic", "Saga orchestrator is a potential bottleneck", "Easier to add new saga steps"] },
      { "title": "Event Sourcing for Core Aggregates", "context": "Need complete audit trail and ability to rebuild state from events.", "decision": "Store all state changes as immutable events in EventStoreDB.", "consequences": ["Complete audit trail", "Time-travel debugging", "Event replay for new projections", "Higher storage costs", "Complex event versioning"] }
    ],
    "tradeoffs": [
      { "dimension": "Consistency vs Performance", "choice": "Eventual consistency for reads", "benefit": "Sub-5ms read latency from optimized read model", "cost": "Read model may be up to 1s behind write model" },
      { "dimension": "Flexibility vs Complexity", "choice": "Flexibility", "benefit": "New read models can be added by creating new projections", "cost": "Multiple databases and projections to maintain" },
      { "dimension": "Coupling vs Visibility", "choice": "Orchestration over choreography", "benefit": "Clear saga flow, easier debugging and monitoring", "cost": "Orchestrator creates a coordination point" }
    ],
    "alternatives": [
      { "name": "Choreography-Based Sagas", "description": "Each service listens for events and reacts independently", "prosVsCons": "Pros: no central coordinator, looser coupling. Cons: hard to debug, implicit workflow, difficult to add compensation", "whyNotChosen": "Orchestration provides better observability and explicit compensation handling" },
      { "name": "State-Based Persistence (No Event Sourcing)", "description": "Store current state only, not event history", "prosVsCons": "Pros: simpler, familiar CRUD. Cons: no audit trail, can't rebuild past state, can't derive new projections", "whyNotChosen": "Event sourcing provides essential audit trail and ability to create new read models retroactively" }
    ]
  }
}
