  "simulation": {
    "chaosScenarios": [
      { "id": "cs-saga-timeout", "name": "Saga Step Timeout", "description": "Payment service times out during an order saga, leaving saga in pending state", "targetNodes": ["payment-svc", "saga-orchestrator"], "faultType": "latency", "severity": 3, "expectedBehavior": "Saga orchestrator times out after 30s. Compensating transactions triggered: inventory reservation released, order marked as failed. Customer notified.", "mitigationSteps": ["Saga timeout triggers compensating actions", "Payment checked for idempotent completion", "Order moved to 'payment_failed' state", "Customer receives failure notification with retry option"] },
      { "id": "cs-event-store-crash", "name": "Event Store Unavailable", "description": "EventStoreDB cluster becomes unavailable", "targetNodes": ["event-store"], "faultType": "crash", "severity": 5, "expectedBehavior": "No new events can be persisted. All command operations fail. Query service continues from read model. Events queued in Kafka for replay.", "mitigationSteps": ["EventStoreDB cluster failover", "Commands return 503 during outage", "Queue events in Kafka for durability", "Replay queued events after recovery", "Verify event sequence integrity"] },
      { "id": "cs-consumer-lag", "name": "Projection Consumer Lag", "description": "Event projector falls behind, causing read model staleness", "targetNodes": ["projector", "kafka-events"], "faultType": "resource-exhaustion", "severity": 2, "expectedBehavior": "Read model shows stale data. Queries return eventually consistent results. Write side unaffected.", "mitigationSteps": ["Scale projector instances", "Optimize projection queries", "Show data freshness indicator to users", "Consider parallel projection for hot paths"] }
    ],
    "bottleneckProgression": [
      { "rpsThreshold": 10000, "bottleneckNode": "event-store", "metric": "disk-io", "description": "Event store write throughput saturates from append-heavy workload", "resolution": "SSD storage, event stream partitioning, batch appends" },
      { "rpsThreshold": 30000, "bottleneckNode": "saga-orchestrator", "metric": "memory", "description": "Active saga instances consume memory for state tracking", "resolution": "Saga state externalization to Redis, increase instances" },
      { "rpsThreshold": 50000, "bottleneckNode": "kafka-events", "metric": "network", "description": "High event volume saturates Kafka broker network", "resolution": "Add brokers, increase partitions, enable compression" }
    ],
    "expectedIssues": [
      { "id": "ei-out-of-order", "title": "Out-of-Order Event Processing", "description": "Events processed out of order by consumers, causing incorrect projections", "affectedNodes": ["projector", "kafka-events"], "likelihood": 3, "impact": 4, "mitigation": "Partition by aggregate ID ensuring ordering, idempotent projectors, sequence number validation" },
      { "id": "ei-schema-break", "title": "Breaking Schema Change", "description": "Event schema update breaks downstream consumers", "affectedNodes": ["schema-registry", "kafka-events"], "likelihood": 3, "impact": 4, "mitigation": "Backward-compatible schema evolution, schema registry enforcement, consumer tolerance for unknown fields" },
      { "id": "ei-dual-write", "title": "Dual Write Inconsistency", "description": "Event store and Kafka can diverge if one write succeeds and other fails", "affectedNodes": ["event-store", "kafka-events"], "likelihood": 2, "impact": 5, "mitigation": "Outbox pattern: write events to DB outbox table, CDC publishes to Kafka" }
    ],
