        { "level": 2, "name": "Feed Team Lead", "responseTimeMinutes": 10, "contacts": ["feed-team-lead"] },
        { "level": 3, "name": "VP Engineering", "responseTimeMinutes": 20, "contacts": ["vp-eng"] }
      ],
      "runbooks": [
        { "incident": "Feed cache failure", "severity": "critical", "steps": ["Trigger Redis failover", "Enable CDN stale cache serving", "Rate-limit feed requests", "Monitor DB connection count", "Rebuild timelines incrementally"], "automatedRecovery": true },
        { "incident": "Fanout pipeline stuck", "severity": "high", "steps": ["Check Kafka broker health", "Restart lagging consumer groups", "Scale fanout workers", "Monitor post visibility delay"], "automatedRecovery": true },
        { "incident": "Viral content spike", "severity": "medium", "steps": ["Cache viral post at CDN edge", "Pre-compute interactions for viral post", "Scale media serving capacity", "Monitor system-wide latency impact"], "automatedRecovery": false }
      ]
    }
  },
  "rationale": {
    "decisions": [
      { "title": "Hybrid Fanout Strategy", "context": "Pure fanout-on-write is expensive for celebrities with millions of followers. Pure fanout-on-read is slow for regular users.", "decision": "Fanout-on-write for users with <100K followers, fanout-on-read merged at query time for celebrities.", "consequences": ["Optimal latency for 99% of feed reads", "Celebrity posts may have slight delay in appearing", "Complex merging logic in feed service"] },
      { "title": "Neo4j for Social Graph", "context": "Need efficient traversal queries for follower lists, mutual friends, and graph-based recommendations.", "decision": "Use Neo4j as the primary social graph store with Redis-cached follower lists for fanout.", "consequences": ["Fast graph traversals for complex queries", "Higher operational complexity than RDBMS", "Need to keep Redis follower cache in sync with Neo4j"] },
      { "title": "ML-Based Feed Ranking", "context": "Chronological feeds lead to information overload. Users engage more with relevant content.", "decision": "ML ranking model scores and reorders feed items based on engagement prediction.", "consequences": ["Higher user engagement and retention", "Potential for filter bubbles", "Need diverse content injection to avoid echo chambers"] }
    ],
    "tradeoffs": [
      { "dimension": "Freshness vs Cost", "choice": "Balanced", "benefit": "Active user feeds are always fresh (pre-computed)", "cost": "Inactive user feeds require on-demand rebuild" },
      { "dimension": "Engagement vs Diversity", "choice": "Engagement with diversity guardrails", "benefit": "ML ranking optimizes for engagement metrics", "cost": "Need explicit diversity injection to prevent filter bubbles" },
      { "dimension": "Write Amplification vs Read Latency", "choice": "Low Read Latency", "benefit": "Fanout-on-write pre-computes timelines, enabling sub-50ms reads", "cost": "Each post generates N writes (one per follower) to feed cache" }
    ],
    "alternatives": [
      { "name": "Pure Fanout-on-Read", "description": "Compute feed at query time by fetching posts from all followed users", "prosVsCons": "Pros: no write amplification. Cons: high read latency, complex query", "whyNotChosen": "Feed read latency would be unacceptable at scale (100ms+ per read)" },
      { "name": "PostgreSQL for Social Graph", "description": "Store follow relationships in PostgreSQL with adjacency list", "prosVsCons": "Pros: simpler ops. Cons: recursive graph queries very slow at scale", "whyNotChosen": "Graph traversals for mutual friends and recommendations need native graph DB performance" }
    ]
  }
}
