  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-feed-cache-crash",
        "name": "Feed Cache Cluster Failure",
        "description": "Redis feed cache cluster goes down, losing all pre-computed timelines",
        "targetNodes": ["feed-cache"],
        "faultType": "crash",
        "severity": 5,
        "expectedBehavior": "Feed reads fall through to database. Response times increase 10-50x. Database connections saturate within minutes.",
        "mitigationSteps": ["Failover to Redis standby cluster", "Rate-limit feed requests to protect DB", "Serve stale cached feeds from CDN", "Gradually rebuild timelines from post DB"]
      },
      {
        "id": "cs-celebrity-post",
        "name": "Celebrity Post Storm",
        "description": "Top 10 celebrities post simultaneously, triggering massive fanout-on-read queries",
        "targetNodes": ["fanout-service", "feed-service"],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Fanout-on-read path load spikes. Feed latency increases for followers of celebrities. Normal user feeds unaffected.",
        "mitigationSteps": ["Pre-compute celebrity posts in hot cache", "Async fanout for celebrity content", "Rate-limit celebrity post frequency", "Scale feed service instances"]
      },
      {
        "id": "cs-graph-db-slowdown",
        "name": "Social Graph Query Slowdown",
        "description": "Neo4j cluster experiences GC pauses causing query timeouts",
        "targetNodes": ["graph-db"],
        "faultType": "latency",
        "severity": 3,
        "expectedBehavior": "Fanout service cannot resolve follower lists. New posts not distributed to timelines. Existing cached feeds continue serving.",
        "mitigationSteps": ["Cache follower lists in Redis as backup", "Reduce graph query complexity", "Investigate and tune GC settings", "Consider follower list denormalization"]
      }
    ],
    "bottleneckProgression": [
      { "rpsThreshold": 100000, "bottleneckNode": "feed-cache", "metric": "memory", "description": "Redis memory fills with pre-computed timelines for 500M+ users", "resolution": "Evict inactive user timelines, add Redis shards" },
      { "rpsThreshold": 200000, "bottleneckNode": "fanout-service", "metric": "cpu", "description": "Fanout workers CPU-bound when distributing posts to millions of followers", "resolution": "Batch fanout writes, increase worker count" },
      { "rpsThreshold": 500000, "bottleneckNode": "post-db", "metric": "disk-io", "description": "Write amplification from post creation + fanout-on-read queries", "resolution": "Shard post DB by user_id, add read replicas" }
    ],
    "expectedIssues": [
      { "id": "ei-feed-staleness", "title": "Feed Staleness for Inactive Users", "description": "Users who log in after days see stale feeds because their timeline cache was evicted", "affectedNodes": ["feed-cache", "feed-service"], "likelihood": 4, "impact": 2, "mitigation": "Rebuild timeline on-demand for returning users, pre-fetch on app open" },
      { "id": "ei-celebrity-fanout", "title": "Celebrity Fanout Latency", "description": "Users with 50M+ followers cause fanout-on-write to take minutes", "affectedNodes": ["fanout-service", "graph-db"], "likelihood": 5, "impact": 3, "mitigation": "Hybrid fanout: on-write for users with <100K followers, on-read for celebrities" },
      { "id": "ei-ranking-bias", "title": "Feed Ranking Filter Bubble", "description": "ML ranking creates echo chambers by optimizing for engagement", "affectedNodes": ["ranking-service"], "likelihood": 4, "impact": 3, "mitigation": "Diversity injection in ranking, expose chronological feed option, regular bias audits" }
    ],
