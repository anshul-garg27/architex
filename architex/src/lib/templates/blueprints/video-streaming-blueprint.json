        { "name": "CDN Cache Hit Drop", "condition": "cache_hit_rate < 90% for 10min", "severity": "warning", "channel": "slack-cdn" },
        { "name": "Slow Stream Start", "condition": "p99_ttfb > 3000ms for 3min", "severity": "critical", "channel": "pagerduty" },
        { "name": "Transcoding Backlog", "condition": "queue_depth > 500 for 15min", "severity": "warning", "channel": "slack-content-ops" }
      ],
      "dashboards": ["Streaming Quality", "CDN Performance", "Content Pipeline", "Recommendations", "Revenue & Engagement"]
    },
    "incidentPlaybook": {
      "escalationPolicy": [
        { "level": 1, "name": "On-Call SRE", "responseTimeMinutes": 3, "contacts": ["oncall-streaming-sre"] },
        { "level": 2, "name": "CDN Team Lead", "responseTimeMinutes": 10, "contacts": ["cdn-team-lead", "streaming-eng-lead"] },
        { "level": 3, "name": "VP Infrastructure", "responseTimeMinutes": 20, "contacts": ["vp-infra", "cto"] }
      ],
      "runbooks": [
        { "incident": "Regional CDN outage", "severity": "critical", "steps": ["Verify DNS failover activated", "Check anycast routing rerouting traffic", "Monitor rebuffer rates in affected region", "Pre-warm alternate PoP caches", "Communicate ETA to customer support"], "automatedRecovery": true },
        { "incident": "Transcoding pipeline stuck", "severity": "high", "steps": ["Check GPU instance health", "Verify input file formats", "Clear stuck jobs from queue", "Scale up GPU fleet", "Re-queue failed jobs"], "automatedRecovery": true },
        { "incident": "Recommendation engine degraded", "severity": "medium", "steps": ["Activate cached recommendations fallback", "Show trending content as default", "Investigate model serving issues", "Rollback model if recent deployment"], "automatedRecovery": true }
      ]
    }
  },
  "rationale": {
    "decisions": [
      { "title": "Adaptive Bitrate Streaming (ABR)", "context": "Users have varying network conditions. Fixed bitrate causes either waste or buffering.", "decision": "Generate multiple quality tiers (480p-4K) per title and use client-side ABR to dynamically select the best quality.", "consequences": ["Smooth playback across network conditions", "4-8x storage per title for multiple encodings", "Transcoding pipeline must process every title at all quality tiers"] },
      { "title": "Cassandra for Viewing History", "context": "Need to store billions of viewing records with high write throughput and tunable consistency.", "decision": "Use Cassandra with local quorum writes for viewing history and playback positions.", "consequences": ["Linear horizontal scalability for writes", "Tunable consistency per query", "Operational complexity of running Cassandra cluster"] },
      { "title": "CDN with Origin Shield", "context": "CDN cache misses create thundering herd to origin storage.", "decision": "Implement mid-tier origin shield between CDN edge and S3 to coalesce cache misses.", "consequences": ["Reduces origin load by 90%", "Additional CDN cost for mid-tier caching", "Slightly higher latency for cache misses (extra hop)"] }
    ],
    "tradeoffs": [
      { "dimension": "Storage Cost vs Startup Latency", "choice": "Low Startup Latency", "benefit": "Pre-encoded at all quality tiers means instant quality selection on playback start", "cost": "4-8x storage overhead per title" },
      { "dimension": "Personalization vs Cold Start", "choice": "Personalization", "benefit": "ML-based recommendations drive 80% of content discovery", "cost": "New users get generic recommendations until sufficient viewing history" },
      { "dimension": "Freshness vs CDN Cost", "choice": "CDN Cost Efficiency", "benefit": "95% cache hit rate minimizes origin bandwidth costs", "cost": "Content updates take up to 1h to propagate to all edge locations" }
    ],
    "alternatives": [
      { "name": "Server-Side Bitrate Selection", "description": "Server decides quality instead of client ABR", "prosVsCons": "Pros: more control. Cons: server doesn't know real-time client network conditions", "whyNotChosen": "Client-side ABR responds faster to network changes, better user experience" },
      { "name": "Real-Time Transcoding", "description": "Transcode on-demand instead of pre-encoding all quality tiers", "prosVsCons": "Pros: massive storage savings. Cons: high compute cost per stream, cold start latency", "whyNotChosen": "At millions of concurrent streams, pre-encoding is far more cost-effective" }
    ]
  }
}
