        { "name": "rebuffer_ratio", "type": "gauge", "description": "Percentage of viewing time spent rebuffering", "nodeId": "cdn-edge" },
        { "name": "cdn_cache_hit_rate", "type": "gauge", "description": "Percentage of video segment requests served from CDN cache", "nodeId": "cdn-edge" },
        { "name": "transcoding_queue_depth", "type": "gauge", "description": "Number of pending transcoding jobs", "nodeId": "transcoding-pipeline" },
