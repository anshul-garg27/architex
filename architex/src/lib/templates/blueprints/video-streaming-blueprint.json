  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-cdn-pop-failure",
        "name": "CDN PoP Outage",
        "description": "Major CDN point-of-presence goes offline affecting a geographic region",
        "targetNodes": ["cdn-edge"],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "Clients in affected region rerouted to next-nearest PoP. Latency increases by 20-50ms. Video quality may temporarily drop due to increased latency.",
        "mitigationSteps": ["DNS failover to alternate PoP", "Anycast routing automatically reroutes", "Pre-warm alternate PoP caches for popular content", "Monitor rebuffering rates in affected region"]
      },
      {
        "id": "cs-origin-storage-latency",
        "name": "Origin Storage Degradation",
        "description": "S3 experiences elevated latency in primary region",
        "targetNodes": ["video-storage"],
        "faultType": "latency",
        "severity": 3,
        "expectedBehavior": "CDN cache hits unaffected (95% of traffic). Cache misses experience 2-5x latency increase. New content uploads delayed.",
        "mitigationSteps": ["Increase CDN cache TTL to reduce origin fetches", "Failover reads to cross-region replica", "Queue non-urgent transcoding jobs", "Alert content ops team"]
      },
      {
        "id": "cs-recommendation-crash",
        "name": "Recommendation Engine Failure",
        "description": "Recommendation service crashes, unable to generate personalized content lists",
        "targetNodes": ["recommendation-engine"],
        "faultType": "crash",
        "severity": 2,
        "expectedBehavior": "Users see trending/popular content instead of personalized recommendations. Engagement metrics may dip but streaming continues unaffected.",
        "mitigationSteps": ["Fall back to cached recommendations (up to 6h old)", "Show trending content as default", "Restart recommendation service", "Backfill recommendations when service recovers"]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 100000,
        "bottleneckNode": "cdn-edge",
        "metric": "network",
        "description": "CDN edge bandwidth saturates in popular regions during prime time",
        "resolution": "Add edge nodes in saturated regions, enable mid-tier caching"
      },
      {
        "rpsThreshold": 500000,
        "bottleneckNode": "playback-service",
        "metric": "cpu",
        "description": "Manifest generation and DRM token computation becomes CPU-bound",
        "resolution": "Pre-generate manifests for popular content, cache DRM tokens"
      },
      {
        "rpsThreshold": 1000000,
        "bottleneckNode": "viewing-history-db",
        "metric": "disk-io",
        "description": "Cassandra write amplification from millions of concurrent viewing position updates",
        "resolution": "Batch viewing position updates, increase compaction throughput"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-rebuffering",
        "title": "Adaptive Bitrate Rebuffering",
        "description": "Aggressive bitrate adaptation causes rebuffering on fluctuating network connections",
        "affectedNodes": ["playback-service", "cdn-edge"],
        "likelihood": 4,
        "impact": 4,
        "mitigation": "Conservative ABR algorithm with buffer-based switching, maintain 30s buffer before quality increase"
      },
      {
        "id": "ei-transcoding-queue",
        "title": "Transcoding Queue Backlog",
        "description": "Large content ingestion (e.g., studio partnership) overwhelms transcoding pipeline",
        "affectedNodes": ["transcoding-pipeline"],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Priority queue for high-value content, auto-scale GPU instances, stagger ingestion batches"
      },
      {
        "id": "ei-cold-start-latency",
        "title": "Cold Start Playback Latency",
        "description": "First playback request for rarely-watched content misses CDN cache, requiring origin fetch",
        "affectedNodes": ["cdn-edge", "video-storage"],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Predictive pre-warming based on recommendation signals, fast-start with lower quality segment"
      }
    ],
    "costBreakdown": {
      "totalMonthlyCostUsd": 250000,
      "components": [
