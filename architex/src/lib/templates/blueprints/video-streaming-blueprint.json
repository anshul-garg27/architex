      { "name": "Rebuffer Rate", "metric": "rebuffer_rate_percent", "target": 1, "unit": "%", "penalty": "Quality credit for sessions with >3% rebuffering" },
      { "name": "Platform Availability", "metric": "uptime_percent", "target": 99.99, "unit": "%", "penalty": "Pro-rated subscription credit" }
    ],
