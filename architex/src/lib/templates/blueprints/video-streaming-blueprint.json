        { "nodeId": "analytics-pipeline", "label": "Spark Analytics", "monthlyCostUsd": 12000, "costDriver": "30 worker nodes" },
        { "nodeId": "recommendation-engine", "label": "Recommendation Engine", "monthlyCostUsd": 10000, "costDriver": "10 ML inference instances" },
        { "nodeId": "metadata-db", "label": "Metadata DB", "monthlyCostUsd": 8000, "costDriver": "Primary + 4 replicas" },
        { "nodeId": "playback-service", "label": "Playback Service", "monthlyCostUsd": 8000, "costDriver": "20 compute instances" },
        { "nodeId": "user-profile-cache", "label": "Redis Cache", "monthlyCostUsd": 7000, "costDriver": "64GB across 8 shards" }
