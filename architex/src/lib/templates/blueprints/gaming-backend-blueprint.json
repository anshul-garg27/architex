    "incidentPlaybook": {
      "escalationPolicy": [
        { "level": 1, "name": "On-Call Game SRE", "responseTimeMinutes": 3, "contacts": ["oncall-game-sre"] },
        { "level": 2, "name": "Game Server Lead", "responseTimeMinutes": 10, "contacts": ["game-server-lead"] },
        { "level": 3, "name": "VP Engineering + Community", "responseTimeMinutes": 20, "contacts": ["vp-eng", "community-manager"] }
      ],
      "runbooks": [
        { "incident": "Mass game server crashes", "severity": "critical", "steps": ["Identify crash pattern (specific map/mode?)", "Scale up replacement servers via Agones", "Redirect players to healthy servers", "Investigate crash dump", "Hotfix if code bug, rollback if deployment issue"], "automatedRecovery": true },
        { "incident": "Matchmaking failure", "severity": "critical", "steps": ["Check matchmaking service health", "Verify player pool data in Redis", "Restart matchmaking workers", "Expand ELO range if pool too thin", "Communicate wait times to players"], "automatedRecovery": true },
        { "incident": "Economy exploit discovered", "severity": "critical", "steps": ["Disable affected transaction type immediately", "Identify all exploiting accounts", "Quantify economic damage", "Rollback exploited transactions", "Ban repeat offenders", "Deploy fix"], "automatedRecovery": false }
      ]
    }
  },
  "rationale": {
    "decisions": [
      { "title": "Server-Authoritative Game State", "context": "Client-authoritative game state is trivially exploitable by cheaters.", "decision": "All game state computed on the server. Clients send inputs, server validates and broadcasts state.", "consequences": ["Eliminates most client-side cheats", "Higher server CPU requirements", "Client-side prediction needed for responsiveness", "Server tick rate limits game responsiveness"] },
      { "title": "Agones for Game Server Orchestration", "context": "Game servers are stateful, short-lived, and need fast scaling.", "decision": "Use Agones on Kubernetes for game server lifecycle management.", "consequences": ["Automated server allocation and shutdown", "Fleet auto-scaling based on demand", "Health monitoring and replacement", "Kubernetes operational complexity"] },
      { "title": "Redis Sorted Sets for Leaderboards", "context": "Leaderboards need O(log N) rank lookups for millions of players.", "decision": "Use Redis sorted sets for real-time leaderboard ranking.", "consequences": ["O(log N) insert and rank lookup", "Supports millions of entries with sub-ms latency", "Memory-constrained: 50 boards x millions of entries"] }
    ],
    "tradeoffs": [
      { "dimension": "Responsiveness vs Security", "choice": "Security with client prediction", "benefit": "Server authority prevents cheating while client prediction masks latency", "cost": "Rubber-banding when prediction diverges from server state" },
      { "dimension": "Cost vs Player Experience", "choice": "Player Experience", "benefit": "Dedicated game servers provide consistent low latency", "cost": "Significantly higher compute cost vs peer-to-peer" },
      { "dimension": "Freshness vs Performance", "choice": "Performance", "benefit": "Leaderboards update every 10s, not every score change", "cost": "Leaderboard positions may be up to 10s stale" }
    ],
    "alternatives": [
      { "name": "Peer-to-Peer Networking", "description": "Players connect directly to each other instead of dedicated servers", "prosVsCons": "Pros: zero server cost. Cons: cheating trivial, NAT traversal issues, worst-player-latency determines experience", "whyNotChosen": "Competitive multiplayer requires server authority for fair play" },
      { "name": "DynamoDB for Leaderboards", "description": "Use DynamoDB with GSI for leaderboard ranking", "prosVsCons": "Pros: managed, durable. Cons: GSI updates async, ranking query expensive at scale", "whyNotChosen": "Redis sorted sets provide O(log N) ranking operations that DynamoDB cannot match" }
    ]
  }
}
