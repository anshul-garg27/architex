  "simulation": {
    "chaosScenarios": [
      { "id": "cs-game-server-crash", "name": "Game Server Crash Mid-Match", "description": "A game server process crashes, disconnecting 100 players from an active match", "targetNodes": ["game-server"], "faultType": "crash", "severity": 4, "expectedBehavior": "Match ends abruptly for affected players. Session state lost for that match. Matchmaking can immediately re-queue players. No XP or rewards from interrupted match.", "mitigationSteps": ["Agones allocator spins up replacement server", "Players auto-reconnect to new server if within timeout", "Match state checkpointed to Redis every 5s for recovery", "Compensate players for interrupted match"] },
      { "id": "cs-matchmaking-overload", "name": "Matchmaking Queue Explosion", "description": "New game launch causes 10x player surge, overwhelming matchmaking", "targetNodes": ["matchmaking", "lobby-service"], "faultType": "resource-exhaustion", "severity": 3, "expectedBehavior": "Match wait times increase from 30s to 5min+. Queue depth grows. Some players abandon queue. Game server capacity saturates.", "mitigationSteps": ["Auto-scale matchmaking instances", "Expand ELO matching range to increase pool", "Pre-scale game server fleet before events", "Show estimated wait time to players"] },
      { "id": "cs-leaderboard-redis-failure", "name": "Leaderboard Redis Failure", "description": "Redis sorted set cluster for leaderboards crashes", "targetNodes": ["leaderboard-redis"], "faultType": "crash", "severity": 2, "expectedBehavior": "Leaderboards show stale data. New score updates queued in Kafka. Game matches continue unaffected. Leaderboard UI shows 'updating' state.", "mitigationSteps": ["Redis failover to replica", "Replay score events from Kafka", "Show cached leaderboard until recovery", "Verify leaderboard consistency post-recovery"] }
    ],
    "bottleneckProgression": [
      { "rpsThreshold": 100000, "bottleneckNode": "game-server", "metric": "cpu", "description": "Game server CPU saturates from physics simulation and state updates", "resolution": "Optimize tick rate, reduce per-player computation, scale server fleet" },
      { "rpsThreshold": 200000, "bottleneckNode": "session-cache", "metric": "memory", "description": "5M+ concurrent player sessions exhaust Redis memory", "resolution": "Add Redis shards, compress session data, shorter TTL for inactive sessions" },
      { "rpsThreshold": 500000, "bottleneckNode": "matchmaking", "metric": "cpu", "description": "Matchmaking algorithm CPU-bound with large player pool", "resolution": "Shard matchmaking by skill tier, pre-compute candidate pools" }
    ],
    "expectedIssues": [
      { "id": "ei-cheating", "title": "Client-Side Cheat Exploits", "description": "Players modify game client to gain unfair advantages (speed hacks, aimbots)", "affectedNodes": ["anti-cheat", "game-server"], "likelihood": 5, "impact": 4, "mitigation": "Server-authoritative game state, input validation, ML anomaly detection, hardware bans" },
      { "id": "ei-rubber-banding", "title": "Network Rubber-Banding", "description": "Players with high latency experience position corrections (rubber-banding)", "affectedNodes": ["state-sync", "game-server"], "likelihood": 4, "impact": 3, "mitigation": "Client-side prediction, server reconciliation, lag compensation, interpolation" },
      { "id": "ei-item-duplication", "title": "Item Duplication Exploit", "description": "Race condition in inventory service allows item duplication", "affectedNodes": ["inventory-service", "player-db"], "likelihood": 2, "impact": 5, "mitigation": "Database-level pessimistic locking for trades, idempotent inventory operations, audit logging" }
    ],
