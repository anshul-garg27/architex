    "performanceTargets": { "defaultRps": 500000, "trafficProfile": "event-driven", "p50LatencyMs": 30, "p99LatencyMs": 80, "availabilityTarget": 99.9, "maxErrorRatePercent": 0.1, "throughputRps": 500000 },
