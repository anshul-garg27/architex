    { "id": "matchmaking", "type": "web-server", "position": { "x": 400, "y": 50 }, "data": { "label": "Matchmaking Engine", "category": "compute", "componentType": "web-server", "icon": "Users", "config": { "instances": 8, "matchTimeoutS": 60, "eloRangeExpansion": true, "poolSizes": 6 }, "state": "idle" } },
    { "id": "game-server", "type": "web-server", "position": { "x": 400, "y": 200 }, "data": { "label": "Game Servers (Agones)", "category": "compute", "componentType": "web-server", "icon": "Server", "config": { "instances": 500, "playersPerServer": 100, "tickRateHz": 20, "maxLatencyMs": 50 }, "state": "idle" } },
    { "id": "state-sync", "type": "web-server", "position": { "x": 400, "y": 350 }, "data": { "label": "State Sync Service", "category": "compute", "componentType": "web-server", "icon": "RefreshCw", "config": { "instances": 12, "deltaCompression": true, "interpolationEnabled": true }, "state": "idle" } },
    { "id": "anti-cheat", "type": "web-server", "position": { "x": 400, "y": 500 }, "data": { "label": "Anti-Cheat Engine", "category": "compute", "componentType": "web-server", "icon": "ShieldAlert", "config": { "instances": 6, "detectionMethods": ["input-validation", "server-authority", "ml-anomaly"], "banThreshold": 0.95 }, "state": "idle" } },
    { "id": "leaderboard-service", "type": "web-server", "position": { "x": 650, "y": 50 }, "data": { "label": "Leaderboard Service", "category": "compute", "componentType": "web-server", "icon": "Trophy", "config": { "instances": 4, "boardCount": 50, "updateIntervalS": 10 }, "state": "idle" } },
    { "id": "inventory-service", "type": "web-server", "position": { "x": 650, "y": 200 }, "data": { "label": "Inventory & Economy", "category": "compute", "componentType": "web-server", "icon": "Coins", "config": { "instances": 6, "itemTypes": 5000, "transactionsPerSec": 10000 }, "state": "idle" } },
    { "id": "session-cache", "type": "cache", "position": { "x": 650, "y": 350 }, "data": { "label": "Session Cache (Redis)", "category": "storage", "componentType": "redis", "icon": "Zap", "config": { "type": "redis", "memoryGB": 128, "shards": 16, "cacheHitRate": 0.98 }, "state": "idle" } },
    { "id": "leaderboard-redis", "type": "cache", "position": { "x": 850, "y": 50 }, "data": { "label": "Leaderboard (Redis Sorted Sets)", "category": "storage", "componentType": "redis", "icon": "BarChart3", "config": { "type": "redis", "memoryGB": 32, "sortedSets": 50 }, "state": "idle" } },
    { "id": "player-db", "type": "database", "position": { "x": 850, "y": 200 }, "data": { "label": "Player DB (PostgreSQL)", "category": "storage", "componentType": "postgresql", "icon": "Database", "config": { "type": "postgresql", "replicas": 3, "maxConnections": 500, "storageGB": 2000 }, "state": "idle" } },
    { "id": "event-bus", "type": "message-queue", "position": { "x": 850, "y": 400 }, "data": { "label": "Kafka (Game Events)", "category": "messaging", "componentType": "kafka", "icon": "ArrowRightLeft", "config": { "partitions": 32, "retentionHours": 48, "throughputMbps": 1000 }, "state": "idle" } },
    { "id": "analytics", "type": "web-server", "position": { "x": 850, "y": 550 }, "data": { "label": "Game Analytics", "category": "compute", "componentType": "web-server", "icon": "BarChart3", "config": { "instances": 4, "metricsCount": 500, "retentionDays": 90 }, "state": "idle" } }
  ],
  "edges": [
