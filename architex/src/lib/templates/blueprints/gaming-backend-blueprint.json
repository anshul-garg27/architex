        { "nodeId": "leaderboard-redis", "label": "Leaderboard Redis", "monthlyCostUsd": 3000, "costDriver": "32GB" },
        { "nodeId": "leaderboard-service", "label": "Leaderboard Service", "monthlyCostUsd": 2000, "costDriver": "4 instances" },
