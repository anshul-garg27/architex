    "slaDefinitions": [
      { "name": "Redirect Latency", "metric": "p99_redirect_latency_ms", "target": 50, "unit": "ms", "penalty": "10% credit per 10ms over target" },
      { "name": "Availability", "metric": "uptime_percent", "target": 99.99, "unit": "%", "penalty": "25% credit per 0.01% under target" },
      { "name": "URL Creation", "metric": "p99_create_latency_ms", "target": 200, "unit": "ms", "penalty": "5% credit per 50ms over target" }
    ],
    "monitoringConfig": {
      "metrics": [
        { "name": "redirect_latency", "type": "histogram", "description": "Time to resolve and redirect a shortened URL", "nodeId": "url-service" },
        { "name": "cache_hit_rate", "type": "gauge", "description": "Redis cache hit rate for URL lookups", "nodeId": "redis-cache" },
        { "name": "db_connection_pool_usage", "type": "gauge", "description": "Active connections / max connections", "nodeId": "primary-db" },
        { "name": "key_pool_remaining", "type": "gauge", "description": "Remaining pre-generated keys in KGS pool", "nodeId": "kgs" },
        { "name": "click_events_per_second", "type": "counter", "description": "Click analytics events ingested", "nodeId": "analytics-queue" }
      ],
      "alerts": [
        { "name": "High Redirect Latency", "condition": "p99_redirect_latency > 100ms for 2min", "severity": "warning", "channel": "slack-eng" },
        { "name": "Cache Hit Rate Drop", "condition": "cache_hit_rate < 0.8 for 5min", "severity": "warning", "channel": "slack-eng" },
        { "name": "DB Connection Saturation", "condition": "db_connections > 90% for 1min", "severity": "critical", "channel": "pagerduty" },
        { "name": "Key Pool Low", "condition": "key_pool_remaining < 100000", "severity": "critical", "channel": "pagerduty" }
      ],
      "dashboards": ["URL Service Overview", "Cache Performance", "Database Health", "Analytics Pipeline", "Abuse Detection"]
    },
    "incidentPlaybook": {
      "escalationPolicy": [
        { "level": 1, "name": "On-Call Engineer", "responseTimeMinutes": 5, "contacts": ["oncall-url-service"] },
        { "level": 2, "name": "Senior Engineer", "responseTimeMinutes": 15, "contacts": ["senior-backend-eng"] },
        { "level": 3, "name": "Engineering Manager", "responseTimeMinutes": 30, "contacts": ["eng-manager", "vp-eng"] }
      ],
      "runbooks": [
        { "incident": "Redis cluster failure", "severity": "critical", "steps": ["Verify Redis health via sentinel", "Trigger failover to standby", "Monitor cache hit rate recovery", "Post-incident: review eviction policies"], "automatedRecovery": true },
        { "incident": "Key pool exhaustion", "severity": "high", "steps": ["Check KGS batch generation logs", "Trigger emergency key batch generation", "Enable inline fallback key generation", "Monitor creation success rate"], "automatedRecovery": true },
        { "incident": "Spike in abuse reports", "severity": "medium", "steps": ["Review abuse detector model scores", "Enable strict rate limiting", "Manually review flagged URLs", "Coordinate with trust & safety team"], "automatedRecovery": false }
      ]
    }
  },
  "rationale": {
    "decisions": [
      { "title": "Pre-generated Key Pool", "context": "URL creation requires a unique short key. Generating keys inline under high concurrency risks collisions.", "decision": "Use a dedicated Key Generation Service that pre-generates keys in batches and hands them out on demand.", "consequences": ["Zero collision risk on key generation", "Slight complexity: KGS is a separate service to maintain", "Key pool needs monitoring for exhaustion"] },
      { "title": "302 Redirects for Analytics", "context": "301 redirects are cached by browsers, preventing per-click analytics. 302 redirects always hit origin.", "decision": "Use 302 redirects for all shortened URLs to enable click tracking.", "consequences": ["Higher origin traffic compared to 301", "Accurate click analytics per URL", "CDN still caches at edge with short TTL"] },
      { "title": "Async Analytics via Kafka", "context": "Logging each click synchronously would add latency to the redirect path.", "decision": "Fire-and-forget click events to Kafka, process asynchronously with ClickHouse for analytics.", "consequences": ["Zero impact on redirect latency", "Analytics data is eventually consistent (sub-second delay)", "Kafka provides durability and replay capability"] }
    ],
    "tradeoffs": [
      { "dimension": "Consistency vs Availability", "choice": "Availability", "benefit": "Redirects always work even during partial failures", "cost": "Newly created URLs may take a few seconds to propagate to all read replicas" },
      { "dimension": "Cost vs Performance", "choice": "Performance", "benefit": "Large Redis cluster provides sub-millisecond reads for 92% of requests", "cost": "Redis cluster accounts for 18% of total infrastructure cost" },
      { "dimension": "Simplicity vs Analytics", "choice": "Analytics", "benefit": "Rich click-through data for URL owners", "cost": "Additional Kafka + ClickHouse pipeline to maintain" }
    ],
    "alternatives": [
      { "name": "NoSQL (DynamoDB) Instead of PostgreSQL", "description": "Use DynamoDB for its auto-scaling and single-digit-ms reads", "prosVsCons": "Pros: auto-scaling, managed. Cons: higher cost at scale, less flexible querying for analytics", "whyNotChosen": "PostgreSQL with read replicas provides better cost efficiency at this scale and supports complex analytics queries" },
      { "name": "Inline Key Generation with Collision Retry", "description": "Generate random Base62 keys inline and retry on collision", "prosVsCons": "Pros: simpler architecture. Cons: collision probability increases with scale, retry adds latency", "whyNotChosen": "At 100K+ RPS write volume, collision retry would cause measurable latency spikes" }
    ]
  }
}
