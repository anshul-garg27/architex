  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-redis-failure",
        "name": "Redis Cluster Failure",
        "description": "Complete Redis cluster outage forcing all reads to hit the database directly",
        "targetNodes": ["redis-cache"],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "Read latency increases 10x. Database connection pool saturates within 30s. Error rate spikes to ~5% before circuit breaker activates fallback.",
        "mitigationSteps": ["Circuit breaker opens, routes reads to read-replicas directly", "Auto-failover to Redis standby cluster", "Gradually warm cache from read-replicas"]
      },
      {
        "id": "cs-db-partition",
        "name": "Database Network Partition",
        "description": "Network partition between primary DB and read replicas causing stale reads",
        "targetNodes": ["primary-db", "read-replicas"],
        "faultType": "partition",
        "severity": 3,
        "expectedBehavior": "Writes succeed on primary but replicas serve stale data. New shortened URLs may not resolve for up to replication lag window.",
        "mitigationSteps": ["Detect replication lag via monitoring", "Route critical reads to primary", "Alert on-call if lag exceeds 30s"]
      },
      {
        "id": "cs-cdn-eviction",
        "name": "CDN Cache Stampede",
        "description": "Mass CDN cache eviction causes thundering herd to origin",
        "targetNodes": ["cdn", "api-gateway"],
        "faultType": "resource-exhaustion",
        "severity": 4,
        "expectedBehavior": "Origin receives 10x normal traffic. API gateway rate limiting activates. Some redirect requests return 429 or 503.",
        "mitigationSteps": ["Request coalescing at CDN edge", "Stale-while-revalidate headers", "Auto-scale URL service instances"]
      },
      {
        "id": "cs-kgs-exhaustion",
        "name": "Key Pool Exhaustion",
        "description": "Pre-generated key pool runs out under sustained high write load",
        "targetNodes": ["kgs"],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "New URL creation requests fail with 503. Existing shortened URLs continue to work. Read path unaffected.",
        "mitigationSteps": ["KGS triggers emergency batch generation", "Fallback to inline Base62 encoding with collision retry", "Alert on key pool < 10% threshold"]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "primary-db",
        "metric": "connections",
        "description": "PostgreSQL connection pool saturates as cache misses increase",
        "resolution": "Add read replicas and increase connection pool size"
      },
      {
        "rpsThreshold": 100000,
        "bottleneckNode": "redis-cache",
        "metric": "memory",
        "description": "Redis memory usage exceeds 80%, eviction rate increases, cache hit rate drops",
        "resolution": "Add Redis shards and increase memory allocation"
      },
      {
        "rpsThreshold": 200000,
        "bottleneckNode": "api-gateway",
        "metric": "cpu",
        "description": "API gateway CPU saturates from TLS termination and rate limiting logic",
        "resolution": "Horizontal scale API gateway, offload TLS to CDN layer"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-hot-urls",
        "title": "Hot URL Concentration",
        "description": "A single viral URL can receive millions of redirects, creating a hot key in Redis and uneven load across shards",
        "affectedNodes": ["redis-cache", "url-service"],
        "likelihood": 4,
        "impact": 3,
        "mitigation": "Client-side caching of popular URLs, Redis local cache, and CDN pinning for viral content"
      },
      {
        "id": "ei-replication-lag",
        "title": "Replication Lag on Writes",
        "description": "Newly created URLs may not resolve immediately due to replication lag between primary and read replicas",
        "affectedNodes": ["primary-db", "read-replicas"],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Write-through to Redis on creation, read-your-writes consistency for the creating user"
      },
      {
        "id": "ei-abuse-links",
        "title": "Malicious URL Abuse",
        "description": "Service used to shorten phishing or malware distribution URLs",
        "affectedNodes": ["abuse-detector", "url-service"],
        "likelihood": 5,
        "impact": 4,
        "mitigation": "Real-time URL scanning, Google Safe Browsing API integration, rate limiting per API key"
      }
    ],
    "costBreakdown": {
      "totalMonthlyCostUsd": 12400,
      "components": [
        { "nodeId": "cdn", "label": "CloudFront CDN", "monthlyCostUsd": 2500, "costDriver": "Data transfer out (50TB/mo)" },
        { "nodeId": "redis-cache", "label": "Redis Cluster", "monthlyCostUsd": 2200, "costDriver": "6 shards x r6g.xlarge" },
        { "nodeId": "primary-db", "label": "PostgreSQL Primary", "monthlyCostUsd": 1800, "costDriver": "db.r6g.2xlarge + 2TB storage" },
        { "nodeId": "read-replicas", "label": "Read Replicas (x3)", "monthlyCostUsd": 2700, "costDriver": "3x db.r6g.xlarge" },
        { "nodeId": "url-service", "label": "URL Service (ECS)", "monthlyCostUsd": 1600, "costDriver": "8 Fargate tasks" },
        { "nodeId": "analytics-queue", "label": "Kafka (MSK)", "monthlyCostUsd": 800, "costDriver": "3 brokers, 12 partitions" },
        { "nodeId": "analytics-db", "label": "ClickHouse", "monthlyCostUsd": 500, "costDriver": "Analytics storage" },
        { "nodeId": "abuse-detector", "label": "Abuse Detection", "monthlyCostUsd": 300, "costDriver": "2 instances + ML inference" }
      ],
      "scalingCostTiers": [
        { "label": "Low (10K RPS)", "rps": 10000, "monthlyCostUsd": 4500 },
        { "label": "Medium (50K RPS)", "rps": 50000, "monthlyCostUsd": 8200 },
        { "label": "High (100K RPS)", "rps": 100000, "monthlyCostUsd": 12400 },
        { "label": "Peak (500K RPS)", "rps": 500000, "monthlyCostUsd": 38000 }
      ]
    },
    "performanceTargets": {
      "defaultRps": 100000,
      "trafficProfile": "bursty",
      "p50LatencyMs": 5,
      "p99LatencyMs": 50,
      "availabilityTarget": 99.99,
