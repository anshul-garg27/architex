        { "level": 2, "name": "AI Platform Lead", "responseTimeMinutes": 15, "contacts": ["ai-platform-lead"] },
        { "level": 3, "name": "VP AI + Security", "responseTimeMinutes": 30, "contacts": ["vp-ai", "security-lead"] }
      ],
      "runbooks": [
        { "incident": "LLM provider outage", "severity": "critical", "steps": ["Verify provider status page", "LLM router auto-failover to secondary", "Monitor response quality on backup provider", "Notify users of potential quality change", "Resume primary when available"], "automatedRecovery": true },
        { "incident": "Sandbox security breach attempt", "severity": "critical", "steps": ["Terminate affected executor instance", "Quarantine session and inputs", "Block the tool/input pattern", "Security team forensic analysis", "Update sandbox security policies"], "automatedRecovery": true },
        { "incident": "Token cost spike", "severity": "high", "steps": ["Identify high-token sessions", "Check for infinite loops or prompt injection", "Apply per-session token budgets", "Throttle non-essential requests"], "automatedRecovery": false }
      ]
