  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-llm-provider-outage",
        "name": "Primary LLM Provider Outage",
        "description": "Anthropic API returns 503 for all requests",
        "targetNodes": ["llm-router"],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "LLM router fails over to secondary provider (OpenAI). Response quality may differ slightly. Latency may increase during failover.",
        "mitigationSteps": ["LLM router detects provider health via circuit breaker", "Automatic failover to secondary provider", "Queue non-urgent requests if all providers degraded", "Notify users of potential quality change"]
      },
      {
        "id": "cs-vector-db-latency",
        "name": "Vector Store Latency Spike",
        "description": "Pinecone query latency increases 10x due to index rebalancing",
        "targetNodes": ["vector-db"],
        "faultType": "latency",
        "severity": 3,
        "expectedBehavior": "RAG retrieval times out. Agent proceeds without retrieval context, relying solely on LLM knowledge. Answer quality degrades for knowledge-intensive queries.",
        "mitigationSteps": ["Cache recent retrieval results in Redis", "Fallback to keyword search on PostgreSQL", "Skip retrieval for simple queries", "Alert on degraded RAG quality"]
      },
      {
        "id": "cs-tool-sandbox-escape",
        "name": "Tool Execution Sandbox Breach",
        "description": "Malicious tool invocation attempts to escape sandboxed execution environment",
        "targetNodes": ["tool-executor"],
        "faultType": "data-corruption",
        "severity": 5,
        "expectedBehavior": "Sandbox detects escape attempt and terminates execution. Agent chain fails for that specific tool call. Security alert triggered.",
        "mitigationSteps": ["gVisor sandbox terminates process", "Block the specific tool/input pattern", "Quarantine the agent session", "Security team investigation", "Update tool allowlist"]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 1000,
        "bottleneckNode": "llm-router",
        "metric": "connections",
        "description": "LLM API rate limits hit, causing request queuing",
        "resolution": "Increase rate limit tier with providers, implement request batching"
      },
      {
        "rpsThreshold": 3000,
        "bottleneckNode": "tool-executor",
        "metric": "cpu",
        "description": "Concurrent tool executions exhaust compute resources",
        "resolution": "Add tool executor instances, implement tool execution prioritization"
      },
      {
        "rpsThreshold": 5000,
        "bottleneckNode": "vector-db",
        "metric": "connections",
        "description": "Vector search query throughput saturates",
        "resolution": "Add Pinecone pods, implement query result caching"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-hallucination",
        "title": "LLM Hallucination in Tool Calls",
        "description": "LLM generates invalid tool parameters or calls nonexistent tools",
        "affectedNodes": ["orchestrator", "tool-executor"],
        "likelihood": 4,
        "impact": 3,
        "mitigation": "Schema validation on all tool calls, retry with corrective prompt, fallback to simpler tool set"
      },
      {
        "id": "ei-infinite-loop",
        "title": "Agent Reasoning Loop",
        "description": "Agent enters infinite reasoning loop, consuming tokens without progress",
        "affectedNodes": ["orchestrator", "llm-router"],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Max step count per chain (20), token budget per session, loop detection via state hash comparison"
      },
      {
        "id": "ei-context-overflow",
        "title": "Context Window Overflow",
        "description": "Long conversations exceed LLM context window, causing truncation of critical information",
        "affectedNodes": ["orchestrator", "memory-store"],
        "likelihood": 4,
        "impact": 3,
        "mitigation": "Sliding window with summarization, store full history in memory store, retrieve relevant context via RAG"
      }
    ],
