  "learnSteps": [
    {
      "title": "Webhook-Triggered Pipeline",
      "description": "A git push triggers a webhook to the API Gateway. The Pipeline Orchestrator parses the pipeline config (YAML), creates a DAG of build steps, and enqueues individual jobs. Each job specifies its container image, commands, dependencies, and resource requirements.",
      "highlightNodes": [
        "developer",
        "api-gw",
        "app-server"
      ],
      "highlightEdges": [
        "e-dev-gw",
        "e-gw-orch"
      ]
    },
    {
      "title": "Job Scheduling and Execution",
      "description": "The Job Queue (SQS) decouples orchestration from execution. Build Workers are ephemeral containers that pull jobs, execute build/test commands, and report results. Workers auto-scale based on queue depth. Each worker runs in an isolated container for security.",
      "highlightNodes": [
        "mq",
        "build-worker"
      ],
      "highlightEdges": [
        "e-orch-mq",
        "e-mq-worker"
      ]
    },
    {
      "title": "Artifact Management",
      "description": "Build artifacts (binaries, Docker images, test reports) are stored in S3 with content-addressable naming. Workers upload artifacts after successful steps. Subsequent pipeline steps can download artifacts from previous steps. Artifacts have configurable retention policies.",
      "highlightNodes": [
        "build-worker",
        "artifact-store"
      ],
      "highlightEdges": [
        "e-worker-artifact"
      ]
    },
    {
      "title": "Pipeline State Machine",
      "description": "PostgreSQL tracks the state of every pipeline, job, and step (pending, running, success, failed, cancelled). The Orchestrator uses this state to determine which jobs to enqueue next (respecting the DAG). Workers update status in real-time, enabling live progress UIs.",
      "highlightNodes": [
        "database",
        "app-server"
      ],
      "highlightEdges": [
        "e-orch-db",
        "e-worker-db"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-build-agent-crash",
        "name": "Build Agent Pool Exhaustion",
        "description": "All build agents crash or become unresponsive",
        "targetNodes": [
          "build-agents"
        ],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "All builds queue. Deployments blocked. Development velocity stops.",
        "mitigationSteps": [
          "Auto-restart agents",
          "Scale agent pool",
          "Prioritize main branch builds"
        ]
      },
      {
        "id": "cs-artifact-storage-full",
        "name": "Artifact Storage Full",
        "description": "Docker registry runs out of storage",
        "targetNodes": [
          "artifact-store"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "New images cannot be pushed. Builds fail at publish step.",
        "mitigationSteps": [
          "Garbage collect old images",
          "Expand storage",
          "Enforce retention policies"
        ]
      },
      {
        "id": "cs-test-flakiness",
        "name": "Widespread Test Flakiness",
        "description": "Flaky tests block all pipelines",
        "targetNodes": [
          "test-runner"
        ],
        "faultType": "error",
        "severity": 2,
        "expectedBehavior": "Pipelines fail randomly. Developer trust erodes.",
        "mitigationSteps": [
          "Quarantine flaky tests",
          "Auto-retry with backoff",
          "Track flake rate per test"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 100,
        "bottleneckNode": "build-agents",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 200,
        "bottleneckNode": "artifact-store",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-ci-cd-pipeline-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "build-agents"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-ci-cd-pipeline-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "test-runner"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-ci-cd-pipeline-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "build-agents"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
