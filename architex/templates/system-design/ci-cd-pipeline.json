  "rationale": {
    "decisions": [
      {
        "title": "Microservice Architecture",
        "context": "Need independent scaling and deployment",
        "decision": "Separate concerns into focused services",
        "consequences": [
          "Independent scaling",
          "Team autonomy",
          "Network overhead"
        ]
      }
    ],
    "tradeoffs": [
      {
        "dimension": "Consistency vs Availability",
        "choice": "Availability",
        "benefit": "System stays up during partial failures",
        "cost": "Brief windows of stale data possible"
      }
    ],
    "alternatives": [
      {
        "name": "Monolithic Architecture",
        "description": "Single deployable unit",
        "prosVsCons": "Simpler but harder to scale independently",
        "whyNotChosen": "Need independent scaling of components"
      }
    ]
  }
}
