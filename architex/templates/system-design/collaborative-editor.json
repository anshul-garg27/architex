  "learnSteps": [
    {
      "title": "Real-Time WebSocket Communication",
      "description": "Clients maintain persistent WebSocket connections to the Collaboration Server. Each keystroke generates an operation (insert/delete at position) that is sent to the server in real-time. The Load Balancer uses consistent hashing on document ID to route all editors of the same document to the same server instance, reducing cross-server coordination.",
      "highlightNodes": ["client", "lb", "app-server"],
      "highlightEdges": ["e-client-lb", "e-lb-app"]
    },
    {
      "title": "CRDT-Based Conflict Resolution",
      "description": "The system uses a CRDT (Conflict-free Replicated Data Type) — specifically a sequence CRDT like Yjs or Automerge — to resolve concurrent edits without a central lock. Each character has a unique ID based on (clientID, sequence). Concurrent insertions at the same position are deterministically ordered by ID. The CRDT state is cached in Redis for fast document loads.",
      "highlightNodes": ["app-server", "cache"],
      "highlightEdges": ["e-app-cache"]
    },
    {
      "title": "Cross-Server Operation Sync",
      "description": "When a document has editors connected to different server instances (due to scaling or reconnects), operations must sync across servers. The Operation Sync Bus (Kafka) broadcasts operations for each document. Each server subscribes to topics for documents it is hosting, applies remote operations to its local CRDT state, and pushes updates to connected clients.",
      "highlightNodes": ["mq", "app-server"],
      "highlightEdges": ["e-app-mq", "e-mq-app"]
    },
    {
      "title": "Document Persistence and Version History",
      "description": "The CRDT state is periodically snapshotted to PostgreSQL (every N operations or every 30 seconds). Full document snapshots are stored in S3 for version history and recovery. PostgreSQL stores metadata (document ID, owner, permissions, last modified). On document open, the server loads the latest CRDT snapshot from Redis (cache hit) or PostgreSQL (cache miss), then replays any operations from Kafka since the snapshot.",
      "highlightNodes": ["database", "storage", "cache"],
      "highlightEdges": ["e-app-db", "e-db-storage", "e-app-cache"]
    }
  ]
}
