  "learnSteps": [
    {
      "title": "URL-Based Transformation Request",
      "description": "Clients request images using URL parameters that encode transformations: /images/photo.jpg?w=400&h=300&format=webp&quality=80. The CDN checks its edge cache first. On a hit (85% of the time for popular images), the processed image is served in <10ms from the nearest edge location. On a miss, the request is forwarded to the origin.",
      "highlightNodes": ["client", "cdn"],
      "highlightEdges": ["e-client-cdn"]
    },
    {
      "title": "Cache-Aside with Processed Image Cache",
      "description": "On a CDN miss, the Image Service first checks Redis using a cache key derived from the image ID + transformation parameters. If found, the processed image bytes are returned immediately. If not, the service dispatches the resize job. Redis acts as a warm L2 cache between the CDN (L1) and the processing pipeline, catching requests that missed the CDN but were recently processed.",
      "highlightNodes": ["app-server", "cache", "lb"],
      "highlightEdges": ["e-lb-app", "e-app-cache"]
    },
    {
      "title": "On-The-Fly Image Processing",
      "description": "Resize Workers fetch the original image from S3, apply the requested transformations (resize, crop, format conversion, quality adjustment) using libvips (fast, memory-efficient), and return the result. The processed image is stored in Redis and the response flows back through the CDN, which caches it at the edge with a long TTL (30 days). Future requests for the same transformation are served from cache.",
      "highlightNodes": ["resize-worker", "storage", "cache"],
      "highlightEdges": ["e-app-worker", "e-worker-storage", "e-app-cache"]
    },
    {
      "title": "Scaling and Cost Optimization",
      "description": "The three-tier cache (CDN edge, Redis, S3) minimizes processing. Workers auto-scale based on CPU utilization. To prevent abuse, the Image Service validates that transformation parameters are within allowed ranges (max 4096px, allowed formats). Pre-warming popular images (generating common sizes at upload time) further reduces on-demand processing. Storage costs are managed by only persisting originals in S3.",
      "highlightNodes": ["cdn", "app-server", "resize-worker", "storage"],
      "highlightEdges": ["e-client-cdn", "e-app-worker", "e-worker-storage"]
    }
  ]
}
