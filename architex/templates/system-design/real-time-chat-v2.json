  "learnSteps": [
    {
      "title": "WebSocket Connection and Message Delivery",
      "description": "Clients maintain persistent WebSocket connections through the Load Balancer (least-connections for sticky sessions). The Chat Service maps userId -> connectionId in Redis for O(1) message routing. When a user sends a message, it is persisted to PostgreSQL, published to Kafka, and fanned out to all online channel members via their WebSocket connections. Messages are sequenced with server-assigned timestamps to resolve ordering.",
      "highlightNodes": ["client", "lb", "chat-app", "database"],
      "highlightEdges": ["e-client-lb", "e-lb-app", "e-app-db"]
    },
    {
      "title": "Presence and Typing Indicators",
      "description": "User presence (online/away/offline) is tracked in Redis with a 5-minute TTL. Clients send heartbeats every 30 seconds; missed heartbeats auto-expire the key. Typing indicators are ephemeral events published directly through Kafka to relevant channel subscribers -- they are never persisted. Redis Pub/Sub broadcasts presence changes to Chat Service instances that hold WebSocket connections for channel members.",
      "highlightNodes": ["chat-app", "presence-cache", "mq"],
      "highlightEdges": ["e-app-cache", "e-app-mq"]
    },
    {
      "title": "Push Notifications for Offline Users",
      "description": "When a message targets an offline user (no Redis presence entry), the Chat Service publishes a push notification event to Kafka. The Push Notification Worker consumes these events, batches them by user (to avoid notification storms), and sends via APNs (iOS) or FCM (Android). Notification preferences (mute channel, DND schedule) are checked against Redis. Workers retry failed deliveries with exponential backoff up to 3 attempts.",
      "highlightNodes": ["mq", "push-worker", "presence-cache"],
      "highlightEdges": ["e-mq-push", "e-app-cache"]
    },
    {
      "title": "File Sharing and Storage",
      "description": "File uploads use pre-signed S3 URLs: the Chat Service generates a pre-signed PUT URL, the client uploads directly to S3 (bypassing the service), and a message with the file reference is created. Kafka triggers async processing (thumbnail generation for images, virus scanning, preview extraction for documents). Files are stored with workspace-level partitioning in S3 for easy lifecycle management and compliance deletion.",
      "highlightNodes": ["chat-app", "file-storage", "mq"],
      "highlightEdges": ["e-app-storage", "e-mq-storage"]
    }
  ]
}
