  "learnSteps": [
    {
      "title": "Content Upload and Async Processing",
      "description": "Users upload text, images, or videos through the API Gateway. The Content Service validates the upload, stores media in S3, creates a content record in PostgreSQL with status 'pending_review', and publishes a moderation job to SQS. The API returns immediately with a 202 Accepted, allowing the user to continue while moderation happens asynchronously.",
      "highlightNodes": ["client", "api-gw", "app-server", "storage"],
      "highlightEdges": ["e-client-gw", "e-gw-app", "e-app-storage", "e-app-mq"]
    },
    {
      "title": "ML-Based Automated Moderation",
      "description": "The ML Moderation service consumes jobs from SQS in batches. GPU-accelerated models classify content across categories: nudity, violence, hate speech, spam, and misinformation. Each category gets a confidence score (0-1). Content scoring above thresholds is auto-rejected; content below safe thresholds is auto-approved. The gray zone (medium confidence) is routed to human review.",
      "highlightNodes": ["mq", "ml-inference"],
      "highlightEdges": ["e-mq-ml"]
    },
    {
      "title": "Decision Persistence and Status Updates",
      "description": "After ML inference, the moderation decision (approved/rejected/needs_review) is written to PostgreSQL. Approved content becomes visible to other users. Rejected content triggers a notification to the uploader with the violation reason. The Content DB maintains a full audit trail of every moderation decision for compliance and appeals.",
      "highlightNodes": ["ml-inference", "database"],
      "highlightEdges": ["e-ml-db", "e-app-db"]
    },
    {
      "title": "Scaling and Model Iteration",
      "description": "The SQS queue absorbs traffic spikes, allowing ML workers to scale independently from the API tier. GPU instances auto-scale based on queue depth. As the moderation model improves, shadow-mode deployment runs new models in parallel without affecting production decisions. Human review feedback is used to retrain models, creating a continuous improvement loop.",
      "highlightNodes": ["mq", "ml-inference", "app-server"],
      "highlightEdges": ["e-app-mq", "e-mq-ml"]
    }
  ]
}
