      "type": "stream-processor",
      "position": {
        "x": 500,
        "y": 200
      },
      "data": {
        "label": "Log Processor (Logstash/Flink)",
        "category": "compute",
        "componentType": "stream-processor",
        "icon": "Activity",
        "config": {
          "parallelism": 32,
          "checkpointIntervalMs": 5000,
          "processingGuarantee": "at-least-once"
        },
        "state": "idle"
      }
    },
    {
