  "edges": [
    {
      "id": "e-app-mq",
      "source": "app-server",
      "target": "mq",
      "sourceHandle": "right",
      "targetHandle": "left-target",
      "type": "data-flow",
      "data": {
        "edgeType": "message",
        "latency": 2,
        "animated": true
      }
    },
    {
      "id": "e-mq-processor",
      "source": "mq",
      "target": "stream-processor",
      "sourceHandle": "right",
      "targetHandle": "left-target",
      "type": "data-flow",
      "data": {
        "edgeType": "stream",
        "latency": 5,
        "animated": true
      }
    },
    {
      "id": "e-processor-es",
      "source": "stream-processor",
      "target": "search-engine",
      "sourceHandle": "right",
      "targetHandle": "left-target",
      "type": "data-flow",
      "data": {
        "edgeType": "index",
        "latency": 10,
        "animated": true
      }
    },
    {
      "id": "e-processor-s3",
      "source": "stream-processor",
      "target": "storage",
      "sourceHandle": "bottom",
      "targetHandle": "top-target",
      "type": "data-flow",
      "data": {
        "edgeType": "write",
        "latency": 50,
        "animated": false
      }
    },
    {
      "id": "e-app-agg",
      "source": "app-server",
      "target": "log-aggregator",
      "sourceHandle": "bottom",
      "targetHandle": "left-target",
      "type": "data-flow",
      "data": {
        "edgeType": "log-forward",
        "latency": 1,
        "animated": true
      }
    },
    {
      "id": "e-agg-mq",
      "source": "log-aggregator",
      "target": "mq",
      "sourceHandle": "top",
      "targetHandle": "bottom-target",
      "type": "data-flow",
      "data": {
        "edgeType": "message",
        "latency": 2,
        "animated": true
      }
    }
  ],
  "learnSteps": [
    {
      "title": "Log Collection and Buffering",
      "description": "Application servers emit structured JSON logs. Fluentd agents (sidecar or daemon) run on each host, buffering logs locally before forwarding to Kafka. This two-tier approach (Fluentd + Kafka) provides back-pressure handling: if downstream processing is slow, Kafka absorbs the burst. No logs are lost during spikes.",
      "highlightNodes": [
        "app-server",
        "log-aggregator",
        "mq"
      ],
      "highlightEdges": [
        "e-app-agg",
        "e-agg-mq",
        "e-app-mq"
      ]
    },
    {
      "title": "Stream Processing and Enrichment",
      "description": "The Log Processor (Logstash or Flink) consumes from Kafka, parses unstructured log lines (grok patterns), enriches with metadata (service name, environment, trace ID), and filters noise. It can also detect anomalies in real-time (error rate spikes) and trigger alerts. The at-least-once guarantee ensures no log events are silently dropped.",
      "highlightNodes": [
        "mq",
        "stream-processor"
      ],
      "highlightEdges": [
        "e-mq-processor"
      ]
    },
    {
      "title": "Hot/Cold Storage Tiering",
      "description": "Recent logs (last 7-30 days) are indexed in Elasticsearch for fast full-text search and dashboards. Older logs are rolled over to S3 as compressed Parquet/JSON for compliance and long-term retention. This tiered approach balances cost (S3 is 10x cheaper) with query performance (Elasticsearch for real-time debugging).",
      "highlightNodes": [
        "search-engine",
        "storage"
      ],
      "highlightEdges": [
        "e-processor-es",
        "e-processor-s3"
      ]
    },
    {
      "title": "Scaling the Ingestion Pipeline",
      "description": "At scale (100K+ hosts, 1M+ logs/sec), Kafka partitions provide horizontal scaling for ingestion. Elasticsearch uses index sharding for parallel indexing. Key tuning knobs: Kafka partition count (parallelism), ES bulk index size (throughput vs latency), and Flink parallelism (processing capacity). Each component scales independently.",
      "highlightNodes": [
        "mq",
        "stream-processor",
        "search-engine"
      ],
      "highlightEdges": [
        "e-mq-processor",
        "e-processor-es"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-es-cluster-red",
        "name": "Elasticsearch Cluster Red",
        "description": "ES cluster goes red due to disk pressure",
        "targetNodes": [
          "elasticsearch"
        ],
        "faultType": "resource-exhaustion",
        "severity": 4,
        "expectedBehavior": "Log ingestion stops. No new logs searchable. Old logs still readable.",
        "mitigationSteps": [
          "Force merge old indices",
          "Delete oldest indices",
          "Expand disk",
          "Apply ILM policies"
        ]
      },
      {
        "id": "cs-log-flood",
        "name": "Log Flood from Bad Deploy",
        "description": "Error loop generates 100x normal log volume",
        "targetNodes": [
          "kafka-ingest",
          "elasticsearch"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Kafka consumer lag grows. ES write queue fills. Important logs delayed.",
        "mitigationSteps": [
          "Rate-limit per service",
          "Drop debug logs during flood",
          "Auto-detect log volume anomalies"
        ]
      },
      {
        "id": "cs-kafka-broker-loss",
        "name": "Kafka Broker Failure",
        "description": "Kafka broker crashes losing some in-flight logs",
        "targetNodes": [
          "kafka-ingest"
        ],
        "faultType": "crash",
        "severity": 3,
        "expectedBehavior": "Brief log gap during leader re-election. No data loss if replicated.",
        "mitigationSteps": [
          "Kafka leader re-election",
          "Producers retry",
          "Verify no under-replicated partitions"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 500000,
        "bottleneckNode": "elasticsearch",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 1000000,
        "bottleneckNode": "kafka-ingest",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-logging-system-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "elasticsearch"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-logging-system-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "kafka-ingest"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-logging-system-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "elasticsearch"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
