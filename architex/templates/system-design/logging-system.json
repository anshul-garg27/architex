        "label": "Log Aggregator (Fluentd)",
        "category": "observability",
        "componentType": "log-aggregator",
        "icon": "FileText",
        "config": {
          "bufferSizeMB": 256,
          "flushIntervalSeconds": 5
        },
        "state": "idle"
      }
