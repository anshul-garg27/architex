        "category": "messaging",
        "componentType": "kafka",
        "icon": "ArrowRightLeft",
        "config": {
          "partitions": 64,
          "retentionHours": 48,
          "maxThroughputMBps": 500
        },
        "state": "idle"
      }
    },
    {
