  "learnSteps": [
    {
      "title": "WebSocket Gateway Architecture",
      "description": "Discord maintains millions of persistent WebSocket connections. The API/WebSocket Gateway authenticates clients, manages connection state, and routes messages. Each gateway server handles ~1M connections using epoll/kqueue. Load balancing uses least-connections to evenly distribute persistent connections.",
      "highlightNodes": ["api-gw", "lb"],
      "highlightEdges": ["e-lb-gw", "e-gw-server"]
    },
    {
      "title": "Message Fanout via Kafka",
      "description": "When a user sends a message, the Chat Service publishes it to Kafka. Kafka partitions by guild/channel ID to maintain ordering. Consumer groups then fan out the message to all gateway servers hosting connected members of that channel, enabling real-time delivery.",
      "highlightNodes": ["web-server", "mq"],
      "highlightEdges": ["e-server-mq"]
    },
    {
      "title": "ScyllaDB for Message Storage",
      "description": "Discord migrated from Cassandra to ScyllaDB for message storage. Messages are partitioned by (channel_id, bucket) with clustering by message_id. This wide-column model allows efficient range queries for channel history while handling trillions of messages across thousands of nodes.",
      "highlightNodes": ["wide-col-db"],
      "highlightEdges": ["e-server-wcdb"]
    },
    {
      "title": "Presence and Session Caching",
      "description": "Redis stores real-time presence data (online/idle/DND status) and session state. With ~150M monthly users, a distributed Redis cluster with consistent hashing ensures sub-millisecond lookups. Presence updates propagate through the same Kafka pipeline as messages.",
      "highlightNodes": ["cache", "mq"],
      "highlightEdges": ["e-server-cache", "e-server-mq"]
    }
  ]
}
