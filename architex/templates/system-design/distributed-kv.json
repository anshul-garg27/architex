  "learnSteps": [
    {
      "title": "Consistent Hashing and Partitioning",
      "description": "Keys are mapped to a hash ring using consistent hashing. Each storage node owns a range of the ring. Virtual nodes (vnodes) ensure even distribution — each physical node has ~256 vnodes. When a node joins/leaves, only keys in adjacent ranges are redistributed, minimizing data movement.",
      "highlightNodes": ["lb", "app-server"],
      "highlightEdges": ["e-client-lb", "e-lb-coord"]
    },
    {
      "title": "Coordinator and Quorum Reads/Writes",
      "description": "The Coordinator Node receives each request and determines which N storage nodes own the key. For a write, it sends the value to all N replicas and waits for W acknowledgments (quorum write). For a read, it queries N replicas and waits for R responses. With N=3, W=2, R=2, you get strong consistency (W+R > N).",
      "highlightNodes": ["app-server", "wide-col-db"],
      "highlightEdges": ["e-coord-storage"]
    },
    {
      "title": "Replication and Hinted Handoff",
      "description": "Each key is replicated to N successor nodes on the hash ring. If a replica is temporarily down, the coordinator sends the write to a healthy node with a 'hint' — the intended destination. When the failed node recovers, hints are replayed from the queue. This achieves high availability even during failures.",
      "highlightNodes": ["wide-col-db", "mq"],
      "highlightEdges": ["e-storage-mq"]
    },
    {
      "title": "LSM-Tree Storage Engine",
      "description": "Each storage node uses an LSM-tree: writes go to an in-memory MemTable, then flush to sorted SSTables on disk. Reads check the MemTable, then Bloom filters on SSTables to skip irrelevant files. Compaction merges SSTables in the background. This design optimizes for write-heavy workloads.",
      "highlightNodes": ["wide-col-db", "cache"],
      "highlightEdges": ["e-coord-storage", "e-coord-cache"]
    }
  ]
}
