  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-index-corruption",
        "name": "Search Index Corruption",
        "description": "ES index segment corruption after disk failure",
        "targetNodes": [
          "elasticsearch"
        ],
        "faultType": "data-corruption",
        "severity": 4,
        "expectedBehavior": "Affected shard returns errors. Partial search results returned.",
        "mitigationSteps": [
          "Promote replica shard",
          "Reindex from source data",
          "Verify index integrity"
        ]
      },
      {
        "id": "cs-query-of-death",
        "name": "Query of Death",
        "description": "Complex regex query causes ES thread pool exhaustion",
        "targetNodes": [
          "elasticsearch"
        ],
        "faultType": "resource-exhaustion",
        "severity": 4,
        "expectedBehavior": "All search queries time out. Search service unavailable.",
        "mitigationSteps": [
          "Circuit breaker on query complexity",
          "Kill long-running queries",
          "Query validation and complexity limits"
        ]
      },
      {
        "id": "cs-ranking-degraded",
        "name": "Ranking Model Degraded",
        "description": "ML ranking model returns poor relevance scores",
        "targetNodes": [
          "ranking-service"
        ],
        "faultType": "error",
        "severity": 2,
        "expectedBehavior": "Search results are less relevant but functional. User engagement drops.",
        "mitigationSteps": [
          "Fallback to BM25 scoring",
          "Rollback to previous model",
          "A/B test before full rollout"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 25000,
        "bottleneckNode": "elasticsearch",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "elasticsearch",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-search-engine-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "elasticsearch"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-search-engine-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "ranking-service"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-search-engine-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "elasticsearch"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
