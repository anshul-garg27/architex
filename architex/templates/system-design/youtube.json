  "learnSteps": [
    {
      "title": "Video Upload Pipeline",
      "description": "When a creator uploads a video, the API Service stores the raw file in object storage and publishes a transcode job to Kafka. The transcoding pipeline (using FFmpeg) generates multiple resolutions (144p to 4K) and formats (H.264, VP9, AV1). Each resolution is split into small chunks for adaptive bitrate streaming.",
      "highlightNodes": ["app-server", "mq", "stream-proc", "storage"],
      "highlightEdges": ["e-app-mq", "e-mq-transcode", "e-transcode-storage"]
    },
    {
      "title": "Video Viewing via CDN",
      "description": "Viewers stream videos from the nearest CDN edge location. The CDN caches popular video chunks (the top 20% of videos get 80% of views). On a cache miss, the CDN pulls from origin object storage. Adaptive bitrate streaming (DASH/HLS) dynamically switches quality based on the viewer's bandwidth.",
      "highlightNodes": ["client", "cdn", "storage"],
      "highlightEdges": ["e-client-cdn", "e-cdn-storage"]
    },
    {
      "title": "Search and Discovery",
      "description": "Video metadata (title, description, tags, auto-generated captions) is indexed in Elasticsearch. The search engine supports fuzzy matching, relevance scoring (combining text relevance, view count, freshness, and user preferences), and autocomplete suggestions.",
      "highlightNodes": ["search", "app-server"],
      "highlightEdges": ["e-app-search"]
    },
    {
      "title": "Metadata and Caching Layer",
      "description": "Video metadata (view counts, likes, channel info) is stored in sharded MySQL. Redis caches hot metadata — trending videos, popular channels, and session data. With billions of daily views, the cache-aside pattern reduces database load by over 90%. View counts use approximate counters to avoid write contention.",
      "highlightNodes": ["database", "cache"],
      "highlightEdges": ["e-app-db", "e-app-cache"]
    }
  ]
}
