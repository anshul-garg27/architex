  "learnSteps": [
    {
      "title": "Inverted Index Architecture",
      "description": "The core of search is the inverted index: a mapping from every word to the list of documents containing it, along with positions and TF-IDF scores. The index is sharded across thousands of machines by document ID. Each query fans out to all shards in parallel, and results are merged by relevance score.",
      "highlightNodes": ["search", "web-server"],
      "highlightEdges": ["e-server-search"]
    },
    {
      "title": "PageRank and Offline Indexing",
      "description": "The Indexer runs as a massive MapReduce job. It reads crawled web pages from GFS, extracts text/links, builds the inverted index, and computes PageRank scores iteratively. PageRank models the web as a graph — a page's rank is proportional to the sum of ranks of pages linking to it, divided by their outbound link count.",
      "highlightNodes": ["batch-proc", "storage"],
      "highlightEdges": ["e-batch-storage", "e-batch-search", "e-batch-db"]
    },
    {
      "title": "Query Serving and Caching",
      "description": "The Query Service first checks the cache for recent identical queries (~30% hit rate for popular queries). On a miss, it parses the query, fans out to index shards, merges results, applies ranking (PageRank + freshness + user signals), and generates snippets. Results are cached for 5 minutes.",
      "highlightNodes": ["web-server", "cache"],
      "highlightEdges": ["e-server-cache", "e-server-search"]
    },
    {
      "title": "Document Retrieval",
      "description": "After the index returns document IDs, the Query Service fetches document metadata (title, URL, snippet candidates) from Bigtable. This two-phase approach (index lookup then doc fetch) keeps the index compact. Bigtable stores the forward index: document ID to full content and metadata.",
      "highlightNodes": ["search", "database"],
      "highlightEdges": ["e-search-db"]
    }
  ]
