  "learnSteps": [
    {
      "title": "Trie Data Structure",
      "description": "The core data structure is a trie (prefix tree). Each node stores a character, and paths from root to node represent prefixes. Each node also stores the top-K suggestions for that prefix, pre-computed and sorted by frequency. This allows O(p) prefix lookup where p is the prefix length.",
      "highlightNodes": [
        "cache"
      ],
      "highlightEdges": []
    },
    {
      "title": "Prefix Caching Strategy",
      "description": "The entire trie is held in Redis, sharded by prefix ranges. Common prefixes (1-3 characters) are cached more aggressively as they cover the most queries. The client debounces keystrokes (100ms) and only sends requests after 2+ characters. This reduces query volume by 80%.",
      "highlightNodes": [
        "cache",
        "web-server",
        "client"
      ],
      "highlightEdges": [
        "e-server-cache",
        "e-client-lb"
      ]
    },
    {
      "title": "Frequency-Based Ranking",
      "description": "Suggestions are ranked by query frequency, freshness, and personalization. The Analytics DB tracks search query frequencies. A batch job periodically rebuilds the trie with updated top-K lists per prefix. Trending queries get a temporary boost factor.",
      "highlightNodes": [
        "database",
        "cache"
      ],
      "highlightEdges": [
        "e-server-db",
        "e-cache-db"
      ]
    },
    {
      "title": "Client-Side Optimization",
      "description": "Clients implement local caching of recent suggestions, debouncing (only query after 100ms of no typing), and optimistic prefetching (pre-request suggestions for the next likely character). These techniques reduce server load by up to 90% while maintaining sub-100ms perceived latency.",
      "highlightNodes": [
        "client",
        "lb"
      ],
      "highlightEdges": [
        "e-client-lb",
        "e-lb-server"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-trie-corruption",
        "name": "Trie Index Corruption",
        "description": "In-memory trie structure becomes corrupted after bad update",
        "targetNodes": [
          "trie-server"
        ],
        "faultType": "data-corruption",
        "severity": 4,
        "expectedBehavior": "Suggestions return incorrect or empty results. Fallback to database prefix query.",
        "mitigationSteps": [
          "Rebuild trie from database",
          "Serve stale suggestions during rebuild",
          "Switch to hot standby"
        ]
      },
      {
        "id": "cs-query-flood",
        "name": "Keystroke Flood",
        "description": "Bot sends 100K keystrokes/sec overwhelming suggestion service",
        "targetNodes": [
          "api-gateway"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Rate limiter activates. Legitimate users see degraded suggestions.",
        "mitigationSteps": [
          "Rate limit per IP/user",
          "Client-side debouncing",
          "CDN-level bot detection"
        ]
      },
      {
        "id": "cs-cache-eviction",
        "name": "Popular Prefix Cache Eviction",
        "description": "Cache churn evicts popular prefixes during peak traffic",
        "targetNodes": [
          "cache"
        ],
        "faultType": "resource-exhaustion",
        "severity": 2,
        "expectedBehavior": "Cache miss rate increases. Trie server load rises.",
        "mitigationSteps": [
          "Pin popular prefixes in cache",
          "Increase cache memory",
          "Use LFU eviction policy"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 10000,
        "bottleneckNode": "trie-server",
        "metric": "memory",
        "description": "Trie memory grows with vocabulary size",
        "resolution": "Shard trie by prefix range"
      },
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "cache",
        "metric": "connections",
        "description": "Redis connection pool exhausted",
        "resolution": "Add Redis shards, connection pooling"
      }
    ],
