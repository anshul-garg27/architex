        "id": "ei-cold-start",
        "title": "Cold Start for New Terms",
        "description": "New trending topics not in trie index",
        "affectedNodes": [
          "trie-server"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Periodic trie rebuild from analytics, streaming updates"
      }
