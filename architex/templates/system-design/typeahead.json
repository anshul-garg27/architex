  "rationale": {
    "decisions": [
      {
        "title": "Trie Data Structure",
        "context": "Need prefix-based lookups in O(k) time",
        "decision": "Use compressed trie (Patricia tree) for prefix matching",
        "consequences": [
          "O(k) lookup time",
          "Memory efficient with compression",
          "Need periodic rebuild for updates"
        ]
      }
    ],
    "tradeoffs": [
      {
        "dimension": "Freshness vs Latency",
        "choice": "Latency",
        "benefit": "In-memory trie provides sub-10ms lookups",
        "cost": "New terms may take minutes to appear"
      }
    ],
    "alternatives": [
      {
        "name": "Elasticsearch Prefix Queries",
        "description": "Use ES for suggestion queries",
        "prosVsCons": "More flexible but 5-10x slower",
        "whyNotChosen": "Latency requirements demand in-memory data structure"
      }
    ]
