  "learnSteps": [
    {
      "title": "Pull-Based Metrics Collection",
      "description": "Prometheus uses a pull model: it scrapes /metrics endpoints from instrumented applications every 15-30 seconds. Applications expose counters, gauges, and histograms in a text format. This pull model means the monitoring system controls the scrape rate and can detect when a target is down (failed scrape).",
      "highlightNodes": [
        "instrumented-app",
        "tsdb"
      ],
      "highlightEdges": [
        "e-app-tsdb"
      ]
    },
    {
      "title": "Time-Series Storage Engine",
      "description": "Prometheus stores time-series data in a custom TSDB optimized for append-heavy workloads. Data is organized in 2-hour blocks with an in-memory head block for recent writes. Blocks are compacted over time. Gorilla-style delta-of-delta encoding achieves ~1.4 bytes per sample. PromQL provides powerful aggregation queries.",
      "highlightNodes": [
        "tsdb"
      ],
      "highlightEdges": [
        "e-app-tsdb"
      ]
    },
    {
      "title": "Alerting Pipeline",
      "description": "The Alert Evaluator periodically runs PromQL alert rules against the TSDB. When a rule fires (e.g., error_rate > 5% for 5 minutes), it creates an alert. Alerts flow through a queue to the Notification Worker, which handles deduplication, grouping, silencing, and routing to PagerDuty/Slack/email.",
      "highlightNodes": [
        "batch-alert",
        "mq",
        "notifier"
      ],
      "highlightEdges": [
        "e-tsdb-alert",
        "e-alert-mq",
        "e-mq-notifier"
      ]
    },
    {
      "title": "Dashboarding and Visualization",
      "description": "Grafana queries Prometheus via PromQL to build real-time dashboards. Queries like rate(http_requests_total[5m]) compute per-second request rates. Grafana supports variable templates, auto-refresh, and drill-down from high-level dashboards to per-instance metrics.",
      "highlightNodes": [
        "dashboard",
        "tsdb"
      ],
      "highlightEdges": [
        "e-dash-tsdb"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-tsdb-overload",
        "name": "TSDB Write Overload",
        "description": "Metrics cardinality explosion overwhelms time-series database",
        "targetNodes": [
          "tsdb"
        ],
        "faultType": "resource-exhaustion",
        "severity": 4,
        "expectedBehavior": "Metrics ingestion falls behind. Dashboards show gaps. Alerts delayed.",
        "mitigationSteps": [
          "Drop low-priority metrics",
          "Rate-limit per metric name",
          "Increase TSDB capacity"
        ]
      },
      {
        "id": "cs-alerting-storm",
        "name": "Alert Storm",
        "description": "Cascading failure triggers thousands of alerts simultaneously",
        "targetNodes": [
          "alerting-engine"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Alert fatigue. Important alerts lost in noise.",
        "mitigationSteps": [
          "Alert grouping and deduplication",
          "Severity-based routing",
          "Alert suppression during known incidents"
        ]
      },
      {
        "id": "cs-collector-crash",
        "name": "Metrics Collector Crash",
        "description": "OpenTelemetry collectors crash across a region",
        "targetNodes": [
          "collectors"
        ],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "Metrics gap for affected services. Alerting blind spots.",
        "mitigationSteps": [
          "Auto-restart collectors",
          "Local buffering on agents",
          "Monitor collector health"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 250000,
        "bottleneckNode": "tsdb",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 500000,
        "bottleneckNode": "alerting-engine",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-metrics-monitoring-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "tsdb"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-metrics-monitoring-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "collectors"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-metrics-monitoring-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "tsdb"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
