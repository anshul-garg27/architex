  "learnSteps": [
    {
      "title": "Multi-Tier Redirect Flow",
      "description": "When a user clicks a short URL, the request first hits the CDN edge. If the redirect is cached (302 with short TTL to preserve analytics), the user is redirected instantly from the edge. On a cache miss, the request reaches the LB, then the URL Service, which checks Redis (90% hit rate) and falls back to PostgreSQL. Using 302 redirects instead of 301 ensures every click passes through the system for tracking.",
      "highlightNodes": ["client", "cdn", "lb", "app-server", "cache"],
      "highlightEdges": ["e-client-cdn", "e-client-lb", "e-lb-app", "e-app-cache"]
    },
    {
      "title": "Click Event Streaming",
      "description": "After resolving the redirect, the URL Service fire-and-forgets a click event to Kafka containing the short URL, timestamp, referrer, user agent, geo (from IP), and device type. This async publish adds <2ms to redirect latency. Kafka retains events for 7 days, enabling replay if the analytics pipeline needs reprocessing.",
      "highlightNodes": ["app-server", "mq"],
      "highlightEdges": ["e-app-mq"]
    },
    {
      "title": "Real-Time Analytics Aggregation",
      "description": "Apache Flink consumes click events and computes windowed aggregations: clicks per minute/hour/day, top referrers, geographic distribution, and device breakdown. These pre-aggregated metrics are written to InfluxDB. Dashboards query InfluxDB directly for sub-second responses on questions like 'clicks in last 24 hours for link X, grouped by country.'",
      "highlightNodes": ["mq", "stream-processor", "tsdb"],
      "highlightEdges": ["e-mq-stream", "e-stream-tsdb"]
    },
    {
      "title": "Balancing Analytics vs Performance",
      "description": "The CDN cache TTL is the key trade-off: a longer TTL (5 min) reduces origin load and speeds up redirects, but undercounts clicks. A shorter TTL (30 sec) captures more clicks but increases origin traffic. The system can also use edge-side logging (CDN access logs piped to Kafka) to capture clicks served from cache, getting both performance and complete analytics.",
      "highlightNodes": ["cdn", "app-server", "mq", "tsdb"],
      "highlightEdges": ["e-client-cdn", "e-app-mq", "e-stream-tsdb"]
    }
  ]
}
