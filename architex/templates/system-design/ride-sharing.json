  "learnSteps": [
    {
      "title": "Real-Time Location Tracking",
      "description": "Drivers send GPS updates every 3-4 seconds to the Ride Service through the Load Balancer. The service writes locations to Redis using GEOADD with a 30-second TTL, so stale drivers are automatically evicted. Redis GEO commands (GEORADIUS) enable O(log N) proximity queries over millions of active drivers. This hot path must be sub-millisecond.",
      "highlightNodes": ["client", "lb", "app-server", "location-cache"],
      "highlightEdges": ["e-client-lb", "e-lb-app", "e-app-cache"]
    },
    {
      "title": "Driver-Rider Matching Algorithm",
      "description": "When a rider requests a ride, the Ride Service publishes a match request to Kafka. The Matching Worker consumes it, queries Redis GEORADIUS for nearby available drivers within expanding radius rings (1km, 3km, 5km), scores them by ETA/rating/acceptance rate, and selects the best match. If no driver accepts within 15 seconds, the worker re-publishes with a wider radius.",
      "highlightNodes": ["app-server", "mq", "matching-worker", "location-cache"],
      "highlightEdges": ["e-app-mq", "e-mq-worker", "e-worker-cache"]
    },
    {
      "title": "Trip State Machine and Persistence",
      "description": "Each trip follows states: REQUESTED -> MATCHED -> DRIVER_EN_ROUTE -> ARRIVED -> IN_PROGRESS -> COMPLETED/CANCELLED. The Trip DB (PostgreSQL) stores trip records with optimistic locking on state transitions to prevent race conditions. All state changes are also published to Kafka for downstream services like billing, analytics, and ETA computation.",
      "highlightNodes": ["app-server", "database", "mq"],
      "highlightEdges": ["e-app-db", "e-app-mq"]
    },
    {
      "title": "Surge Pricing and Demand Balancing",
      "description": "The Matching Worker calculates supply-demand ratios per geospatial cell (H3 hexagons). When demand exceeds supply by a threshold, surge multipliers are computed and cached in Redis. The Ride Service reads surge pricing before confirming a ride request. Kafka streams aggregate demand signals across workers for consistent pricing. Surge rebalances supply by incentivizing drivers to move to high-demand areas.",
      "highlightNodes": ["matching-worker", "location-cache", "mq"],
      "highlightEdges": ["e-worker-cache", "e-mq-worker"]
    }
  ]
}
