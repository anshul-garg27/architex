  "learnSteps": [
    {
      "title": "Audio Delivery via CDN",
      "description": "Spotify pre-encodes audio in multiple bitrates (96/160/320 kbps) and stores chunks in object storage. The CDN caches popular tracks at 200+ edge locations. Clients use adaptive bitrate streaming, fetching the next chunk while playing the current one, achieving ~95% cache hit rate for popular songs.",
      "highlightNodes": ["cdn", "storage", "client"],
      "highlightEdges": ["e-client-cdn", "e-cdn-storage"]
    },
    {
      "title": "Recommendation Pipeline",
      "description": "Spotify's recommendation engine combines collaborative filtering (users who liked X also liked Y), content-based analysis (audio features via CNNs), and NLP on playlist names. The ML Inference service serves real-time recommendations. Kafka streams listening events to continuously retrain models offline.",
      "highlightNodes": ["ml-reco", "mq"],
      "highlightEdges": ["e-app-ml", "e-mq-ml"]
    },
    {
      "title": "Metadata and Playlist Service",
      "description": "The Playback Service handles song metadata, user playlists, and playback state. PostgreSQL stores normalized data (users, artists, albums, playlists). Redis caches active session data and frequently accessed metadata, reducing database load by 90%.",
      "highlightNodes": ["app-server", "database", "cache"],
      "highlightEdges": ["e-app-db", "e-app-cache"]
    },
    {
      "title": "Event-Driven Architecture",
      "description": "Every user action (play, skip, save, search) is published to Kafka. These events feed the recommendation model training pipeline, analytics dashboards, royalty calculation systems, and A/B testing frameworks. This decoupled architecture allows independent scaling of consumers.",
      "highlightNodes": ["app-server", "mq", "ml-reco"],
      "highlightEdges": ["e-app-mq", "e-mq-ml"]
    }
  ]
}
