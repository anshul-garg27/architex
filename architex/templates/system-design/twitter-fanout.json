  "learnSteps": [
    {
      "title": "Fanout-on-Write (Push Model)",
      "description": "When a user posts a tweet, the Fanout Service pushes the tweet ID to every follower's timeline in Redis. This pre-computes timelines so reads are instant (O(1) cache lookup). Kafka decouples the write from fanout, allowing async processing of millions of follower updates.",
      "highlightNodes": [
        "fanout-service",
        "message-queue",
        "timeline-cache"
      ],
      "highlightEdges": [
        "e-fanout-kafka",
        "e-kafka-cache"
      ]
    },
    {
      "title": "Fanout-on-Read for Hot Users",
      "description": "Celebrity accounts with millions of followers make fanout-on-write expensive (1 tweet = millions of cache writes). For hot users, their tweets are merged at read time instead. The Tweet Service fetches followed celebrity tweets from the DB and merges with the cached timeline.",
      "highlightNodes": [
        "tweet-service",
        "user-db"
      ],
      "highlightEdges": [
        "e-tweet-db",
        "e-tweet-cache"
      ]
    },
    {
      "title": "Timeline Cache Architecture",
      "description": "Each user's timeline is stored as a Redis sorted set (score = timestamp). The cache holds the last ~800 tweet IDs per user. With a 90% cache hit rate, most timeline reads are sub-millisecond. Redis cluster is sharded by userId for horizontal scaling.",
      "highlightNodes": [
        "timeline-cache"
      ],
      "highlightEdges": [
        "e-kafka-cache",
        "e-tweet-cache"
      ]
    },
    {
      "title": "Kafka Partitioning Strategy",
      "description": "Kafka topics are partitioned by userId (12 partitions). This ensures all fanout events for a user's followers go to the same partition, maintaining ordering. The replication factor of 3 provides fault tolerance. Consumer groups process partitions in parallel.",
      "highlightNodes": [
        "message-queue"
      ],
      "highlightEdges": [
        "e-fanout-kafka",
        "e-kafka-cache"
      ]
    },
    {
      "title": "Media Delivery via CDN",
      "description": "Tweet images and videos are served through the CDN with a 95% hit rate at 100+ edge locations. Media is stored in object storage and cached at the edge with long TTLs (7 days). This offloads 95% of media bandwidth from origin servers.",
      "highlightNodes": [
        "cdn"
      ],
      "highlightEdges": [
        "e-tweet-cdn"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-fanout-lag",
        "name": "Fanout Worker Lag",
        "description": "Fanout workers fall behind during celebrity tweet storm",
        "targetNodes": [
          "fanout-workers"
        ],
        "faultType": "resource-exhaustion",
        "severity": 4,
        "expectedBehavior": "Timeline updates delayed by minutes for followers. Celebrity tweets take longer to appear.",
        "mitigationSteps": [
          "Scale fanout workers",
          "Switch celebrity to fanout-on-read",
          "Priority queue for high-engagement users"
        ]
      },
      {
        "id": "cs-timeline-cache-crash",
        "name": "Timeline Cache Failure",
        "description": "Redis timeline cache cluster goes down",
        "targetNodes": [
          "timeline-cache"
        ],
        "faultType": "crash",
        "severity": 5,
        "expectedBehavior": "All timeline reads hit database. Massive latency increase. Some timelines unavailable.",
        "mitigationSteps": [
          "Redis failover to standby",
          "Rate-limit timeline reads",
          "Serve stale CDN-cached timelines"
        ]
      },
      {
        "id": "cs-tweet-storm",
        "name": "Viral Tweet Cascade",
        "description": "Single tweet gets 1M retweets in 5 minutes",
        "targetNodes": [
          "fanout-workers",
          "timeline-cache"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Fanout queue backs up. Hot tweet cached at CDN edge.",
        "mitigationSteps": [
          "Deduplicate retweet fanout",
          "CDN cache for hot tweets",
          "Rate-limit retweet fanout per tweet"
        ]
      }
    ],
