  "learnSteps": [
    {
      "title": "Order Flow Architecture",
      "description": "When a customer places an order, the Order Service validates it (menu availability, pricing, address), processes payment, and publishes an OrderCreated event to Kafka. This event-driven design decouples order placement from restaurant notification and driver dispatch.",
      "highlightNodes": ["mobile-client", "app-server", "mq"],
      "highlightEdges": ["e-client-gw", "e-lb-app", "e-app-mq"]
    },
    {
      "title": "Driver Dispatch Optimization",
      "description": "The Dispatch Worker consumes order events and matches them with available drivers. It uses a geospatial index (Redis GEO or H3 hexagonal grid) to find nearby drivers. The matching algorithm optimizes for minimizing total delivery time across all active orders, considering driver location, restaurant prep time, and traffic.",
      "highlightNodes": ["dispatch-worker", "mq"],
      "highlightEdges": ["e-mq-dispatch"]
    },
    {
      "title": "Real-Time Order Tracking",
      "description": "Drivers publish GPS locations every 4 seconds. These locations update a Redis GEO set for dispatch and are pushed to customers via WebSocket/SSE. The order state machine (placed, accepted, preparing, picked_up, delivering, delivered) transitions are stored in PostgreSQL and broadcast in real-time.",
      "highlightNodes": ["cache", "database", "dispatch-worker"],
      "highlightEdges": ["e-dispatch-db", "e-app-cache"]
    },
    {
      "title": "Restaurant and Menu Caching",
      "description": "Restaurant menus, hours, and availability are cached in Redis with a 30-minute TTL. Restaurants update menus via a dashboard, invalidating the cache. Popular restaurants near a user are pre-fetched. Image assets (food photos) are stored in S3 and served via CDN.",
      "highlightNodes": ["cache", "storage", "app-server"],
      "highlightEdges": ["e-app-cache", "e-client-storage"]
    }
  ]
