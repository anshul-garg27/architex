  "learnSteps": [
    {
      "title": "API Gateway as Single Entry Point",
      "description": "All client requests pass through the API Gateway, which handles authentication (JWT validation), rate limiting, request routing, and response aggregation. The gateway maps external API paths to internal service endpoints, shielding clients from service topology changes. It also handles cross-cutting concerns like CORS, request logging, and circuit breaking.",
      "highlightNodes": ["client", "api-gw"],
      "highlightEdges": ["e-client-gw"]
    },
    {
      "title": "Load-Balanced Service Instances",
      "description": "The internal Load Balancer distributes requests across multiple instances of each service using round-robin with health checks. Each service registers itself via service discovery. The LB enables horizontal scaling: the Order Service runs 5 instances during peak load but scales down during off-peak. gRPC is used for inter-service communication for lower latency and strong typing.",
      "highlightNodes": ["lb", "user-service", "order-service", "product-service"],
      "highlightEdges": ["e-gw-lb", "e-lb-user", "e-lb-order", "e-lb-product"]
    },
    {
      "title": "Shared Cache and Database Per Service",
      "description": "Redis provides a shared caching layer for frequently accessed data (user profiles, product catalog). Each service logically owns its own tables in PostgreSQL (schema-per-service pattern). The User Service caches profiles in Redis to avoid hitting the DB on every auth check. Services never directly query another service's tables, enforcing loose coupling.",
      "highlightNodes": ["cache", "database", "user-service", "order-service"],
      "highlightEdges": ["e-user-cache", "e-order-db", "e-product-db"]
    },
    {
      "title": "Async Event-Driven Communication",
      "description": "Services communicate asynchronously via Kafka for non-latency-critical operations. When the Order Service creates an order, it publishes an 'OrderCreated' event. The Product Service consumes it to update inventory. This event-driven approach eliminates synchronous dependencies between services, improving resilience. If the Product Service is down, events queue in Kafka and are processed when it recovers.",
      "highlightNodes": ["order-service", "product-service", "mq"],
      "highlightEdges": ["e-order-mq", "e-product-mq"]
    }
  ]
}
