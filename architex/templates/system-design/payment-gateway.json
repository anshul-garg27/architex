  "learnSteps": [
    {
      "title": "Idempotent Charge Creation",
      "description": "Merchants send charge requests with an idempotency key (UUID) to the API Gateway. The Payment Service checks PostgreSQL for an existing charge with that key. If found, it returns the cached result (idempotent retry). If not, it creates a new charge record with status PENDING in a serializable transaction. This prevents duplicate charges from network retries. The API Gateway enforces per-merchant rate limits and API key authentication.",
      "highlightNodes": ["client", "api-gw", "payment-app", "database"],
      "highlightEdges": ["e-client-gw", "e-gw-app", "e-app-db"]
    },
    {
      "title": "Async Payment Processing",
      "description": "After creating a PENDING charge, the Payment Service publishes a process event to Kafka and returns a 202 Accepted. The Payment Processor Worker consumes the event and calls the bank/card network API (Visa, Mastercard, ACH). Bank APIs have ~800ms latency and ~3% error rate. This async pattern decouples the fast API response from slow bank processing, preventing client timeouts on long-running bank calls.",
      "highlightNodes": ["payment-app", "mq", "process-worker"],
      "highlightEdges": ["e-app-mq", "e-mq-worker"]
    },
    {
      "title": "Bank Integration and Settlement",
      "description": "The Worker sends the charge to the bank API with transaction details. On success, it updates the Ledger DB to SUCCEEDED and creates double-entry accounting records (debit merchant, credit platform). On failure, it marks FAILED and triggers retry with exponential backoff (up to 5 attempts). Bank declines are terminal and not retried. The Worker uses distributed locks to prevent concurrent processing of the same charge.",
      "highlightNodes": ["process-worker", "bank-api", "database"],
      "highlightEdges": ["e-worker-bank", "e-worker-db"]
    },
    {
      "title": "Exactly-Once Processing and Audit Trail",
      "description": "The system achieves exactly-once semantics through idempotency keys at the API level and transactional outbox pattern at the DB level. Every state transition is logged in an immutable audit table. Kafka retains events for 30 days for replay and reconciliation. Daily batch reconciliation compares the ledger against bank settlement files to detect discrepancies. PCI compliance is achieved by tokenizing card data before it reaches the Payment Service.",
      "highlightNodes": ["payment-app", "database", "mq"],
      "highlightEdges": ["e-app-db", "e-app-mq"]
    }
  ]
}
