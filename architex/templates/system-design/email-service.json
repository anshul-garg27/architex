  "learnSteps": [
    {
      "title": "API Ingestion and Validation",
      "description": "Client applications submit email requests (recipient, template ID, variables) via the API. The Email Service validates inputs, checks the sender's domain (SPF/DKIM records), enforces per-account rate limits, and persists the email record to PostgreSQL. The API returns a 202 Accepted immediately \u2014 actual sending is asynchronous.",
      "highlightNodes": [
        "client",
        "api-gw",
        "app-server"
      ],
      "highlightEdges": [
        "e-client-gw",
        "e-gw-app",
        "e-app-db"
      ]
    },
    {
      "title": "Queue-Based Delivery with Retry",
      "description": "Emails are published to Kafka partitioned by recipient domain (batching to same ISP). SMTP Send Workers consume and deliver via SMTP. Transient failures (4xx) trigger exponential backoff retries (up to 5 attempts over 24 hours). Permanent failures (5xx, invalid address) are marked as bounced. This decouples ingestion throughput from SMTP delivery speed.",
      "highlightNodes": [
        "mq",
        "send-worker",
        "smtp"
      ],
      "highlightEdges": [
        "e-app-mq",
        "e-mq-worker",
        "e-worker-smtp"
      ]
    },
    {
      "title": "Bounce and Complaint Handling",
      "description": "The SMTP Worker tracks delivery status (delivered, bounced, deferred, complained). Bounce notifications from ISPs update the Email DB. Hard-bounced addresses are added to a suppression list to protect sender reputation. Complaint feedback loops (FBL) from ISPs are processed similarly. This data drives deliverability dashboards.",
      "highlightNodes": [
        "send-worker",
        "database",
        "smtp"
      ],
      "highlightEdges": [
        "e-worker-smtp",
        "e-worker-db"
      ]
    },
    {
      "title": "Throughput and IP Warm-Up",
      "description": "New sending IPs have no reputation with ISPs. The system gradually increases volume per IP (warm-up schedule). Workers are assigned to IP pools, and each pool has a sending rate limit. Kafka partitioning by domain ensures ISP-specific throttling. At scale, the system manages thousands of IPs across multiple ISPs for optimal deliverability.",
      "highlightNodes": [
        "send-worker",
        "mq"
      ],
      "highlightEdges": [
        "e-mq-worker",
        "e-worker-smtp"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-smtp-bounce-storm",
        "name": "SMTP Bounce Storm",
        "description": "Bad recipient list causes mass bounces from ISP",
        "targetNodes": [
          "smtp-relay"
        ],
        "faultType": "error",
        "severity": 4,
        "expectedBehavior": "ISP blocks sending IP. Delivery rate drops to zero for that ISP.",
        "mitigationSteps": [
          "Automatic bounce rate monitoring",
          "IP warming rotation",
          "Recipient validation before send"
        ]
      },
      {
        "id": "cs-template-rendering-crash",
        "name": "Template Engine Crash",
        "description": "Email template rendering fails due to bad data",
        "targetNodes": [
          "template-service"
        ],
        "faultType": "crash",
        "severity": 3,
        "expectedBehavior": "Emails queued but not rendered. Delivery paused.",
        "mitigationSteps": [
          "Template validation in CI",
          "Fallback to plaintext",
          "Isolate bad template"
        ]
      },
      {
        "id": "cs-queue-backup",
        "name": "Email Queue Backlog",
        "description": "Marketing blast creates millions of queued emails",
        "targetNodes": [
          "email-queue"
        ],
        "faultType": "resource-exhaustion",
        "severity": 2,
        "expectedBehavior": "Transactional emails delayed behind marketing volume.",
        "mitigationSteps": [
          "Priority queue for transactional",
          "Rate limiting for marketing",
          "Separate queues by priority"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 2500,
        "bottleneckNode": "smtp-relay",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 5000,
        "bottleneckNode": "template-service",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-email-service-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "smtp-relay"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-email-service-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "email-queue"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-email-service-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "smtp-relay"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
