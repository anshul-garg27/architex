  "learnSteps": [
    {
      "title": "Real-Time State via WebSocket",
      "description": "Game clients maintain persistent WebSocket connections through the Load Balancer to authoritative Game Servers. The LB uses least-connections routing to ensure even distribution. Each Game Server hosts multiple game sessions, running a tick-based loop (e.g., 60 Hz) that processes player inputs, updates game state, and broadcasts state deltas back to all connected clients in the session.",
      "highlightNodes": ["client", "lb", "game-server"],
      "highlightEdges": ["e-client-lb", "e-lb-game"]
    },
    {
      "title": "In-Memory Game State with Redis",
      "description": "The authoritative game state for each active session lives in Redis, enabling sub-millisecond reads/writes. Redis Sorted Sets track leaderboards, and Hash types store player positions and inventories. When a Game Server crashes, another can resume the session by loading state from Redis. The TTL ensures abandoned sessions are garbage-collected automatically.",
      "highlightNodes": ["game-server", "cache"],
      "highlightEdges": ["e-game-cache"]
    },
    {
      "title": "Asynchronous Matchmaking",
      "description": "When a player queues for a match, the Game Server publishes a matchmaking request to Kafka. Matchmaking Workers consume these requests and run ELO/MMR-based algorithms to form balanced teams. Once a match is formed, the worker writes the match assignment to PostgreSQL and notifies the Game Server, which then routes players to the allocated session.",
      "highlightNodes": ["mq", "matchmaking-worker", "database"],
      "highlightEdges": ["e-game-mq", "e-mq-worker", "e-worker-db"]
    },
    {
      "title": "Persistence and Player Profiles",
      "description": "Player profiles, match history, inventories, and progression are durably stored in PostgreSQL. Game Servers write match results and reward grants at session end. Read replicas serve profile lookups and leaderboard queries. The separation of hot state (Redis) from cold state (PostgreSQL) lets the system handle millions of concurrent players while keeping match data durable.",
      "highlightNodes": ["database", "game-server", "cache"],
      "highlightEdges": ["e-game-db", "e-game-cache"]
    }
  ]
}
