  "learnSteps": [
    {
      "title": "Data Ingestion and Feature Engineering",
      "description": "The Data Ingestion pipeline (Spark) runs daily, pulling raw data from upstream sources, cleaning and transforming it, and writing curated datasets to the Data Lake (S3) as Parquet files partitioned by date. It also computes and materializes features into the Feature Store (Redis) for low-latency online serving. Feature engineering logic is versioned and tested alongside model code to ensure reproducibility.",
      "highlightNodes": ["data-processor", "data-lake", "feature-store"],
      "highlightEdges": ["e-ingest-lake", "e-ingest-features"]
    },
    {
      "title": "Model Training and Experimentation",
      "description": "The Training Cluster reads curated datasets from S3 and trains models on GPU instances. Hyperparameter tuning runs multiple experiments in parallel. Training metrics (loss, accuracy, AUC) are tracked by Prometheus and logged to an experiment tracker. Once a model meets quality thresholds, it is serialized (ONNX/TorchScript) and pushed to the Model Registry with metadata (training data version, hyperparameters, metrics).",
      "highlightNodes": ["data-lake", "training-cluster", "model-registry", "metrics"],
      "highlightEdges": ["e-lake-train", "e-train-registry", "e-train-metrics"]
    },
    {
      "title": "Model Serving and Inference",
      "description": "The Model Serving API loads the latest approved model from the Registry on startup. It receives prediction requests, fetches real-time features from the Feature Store, and delegates to the Inference Engine (GPU) for computation. Batch requests are dynamically grouped for GPU efficiency. Blue-green deployment ensures zero-downtime model updates. The Serving API supports A/B testing by routing traffic percentages to different model versions.",
      "highlightNodes": ["model-registry", "serving-app", "inference-engine", "feature-store"],
      "highlightEdges": ["e-registry-serve", "e-serve-inference", "e-features-inference"]
    },
    {
      "title": "Monitoring and Model Drift Detection",
      "description": "Prometheus collects serving metrics (latency, throughput, error rate) and model quality metrics (prediction distribution, feature drift scores). Data drift is detected by comparing live feature distributions against training data statistics. When drift exceeds thresholds, alerts trigger and the pipeline can automatically kick off retraining. This closed loop ensures models stay accurate as real-world data evolves over time.",
      "highlightNodes": ["serving-app", "metrics", "training-cluster"],
      "highlightEdges": ["e-serve-metrics", "e-train-metrics"]
    }
  ]
}
