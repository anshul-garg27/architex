  "learnSteps": [
    {
      "title": "Upload Flow with Pre-Signed URLs",
      "description": "The client requests an upload URL from the App Server, which generates a pre-signed S3 URL. The client uploads the raw video directly to S3 (bypassing the app server for large files). Once the upload completes, S3 triggers a notification, and the App Server publishes a transcode job to the queue. This pattern avoids bottlenecking the app tier with large file transfers.",
      "highlightNodes": ["client", "app-server", "storage"],
      "highlightEdges": ["e-client-gw", "e-gw-app", "e-app-mq"]
    },
    {
      "title": "Multi-Resolution Transcoding Pipeline",
      "description": "The Transcode Worker pulls jobs from SQS and runs FFmpeg to produce multiple resolutions (360p, 720p, 1080p, 4K) and formats (H.264, VP9, AV1). Each resolution is a separate output file stored in S3. Workers use spot instances for cost optimization. A single 1-hour 4K video may take 2-6 hours of compute across all output formats.",
      "highlightNodes": ["mq", "transcode-worker", "storage"],
      "highlightEdges": ["e-mq-worker", "e-worker-storage"]
    },
    {
      "title": "CDN Delivery and Adaptive Bitrate",
      "description": "Transcoded videos are served via CloudFront CDN with 200+ edge locations. The player uses HLS/DASH adaptive bitrate streaming — it requests small chunks (2-10 second segments) and switches resolutions based on available bandwidth. Popular videos have high cache hit rates at the edge, reducing origin load and latency.",
      "highlightNodes": ["storage", "cdn"],
      "highlightEdges": ["e-storage-cdn"]
    },
    {
      "title": "Metadata and Processing State Machine",
      "description": "Video metadata (title, duration, resolution, processing status) is tracked in PostgreSQL. The processing state machine: uploaded -> processing -> processed -> published (or failed). The Transcode Worker updates status on completion. The App Server reads this to show upload progress. Eventual consistency is acceptable — the video appears within minutes.",
      "highlightNodes": ["database", "app-server", "transcode-worker"],
      "highlightEdges": ["e-app-db", "e-worker-db"]
    }
  ]
}
