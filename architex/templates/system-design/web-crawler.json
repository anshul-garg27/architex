  "learnSteps": [
    {
      "title": "URL Frontier Design",
      "description": "The URL Frontier is a priority queue with two sub-components: a front queue (prioritizes by page importance \u2014 PageRank, freshness) and a back queue (enforces politeness \u2014 one connection per host at a time). URLs are partitioned by domain to prevent overwhelming any single server.",
      "highlightNodes": [
        "url-frontier",
        "scheduler"
      ],
      "highlightEdges": [
        "e-sched-frontier"
      ]
    },
    {
      "title": "Distributed Fetching",
      "description": "500 fetcher workers pull URLs from the frontier. Each checks the DNS/robots.txt cache before fetching. Workers respect crawl-delay directives and maintain per-host rate limits. Content is fingerprinted (SimHash) for near-duplicate detection before storing.",
      "highlightNodes": [
        "fetcher",
        "cache"
      ],
      "highlightEdges": [
        "e-frontier-fetcher",
        "e-fetcher-cache"
      ]
    },
    {
      "title": "URL Deduplication",
      "description": "Before adding a discovered URL to the frontier, the system checks a Bloom filter (in-memory, ~10GB for 10B URLs, 1% false positive rate). URLs passing the Bloom filter are verified against the URL DB. This two-tier approach avoids re-crawling billions of already-visited pages.",
      "highlightNodes": [
        "url-db",
        "scheduler"
      ],
      "highlightEdges": [
        "e-fetcher-urldb",
        "e-urldb-sched"
      ]
    },
    {
      "title": "Content Processing Pipeline",
      "description": "Fetched pages are stored in S3 for later reprocessing. The indexing pipeline extracts text, parses links (to feed back to the frontier), and builds the inverted index in Elasticsearch. Links are normalized (remove fragments, canonicalize) before being added back to the scheduler.",
      "highlightNodes": [
        "page-storage",
        "search-index"
      ],
      "highlightEdges": [
        "e-fetcher-storage",
        "e-fetcher-index"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-dns-failure",
        "name": "DNS Resolver Failure",
        "description": "DNS resolver cache expires and upstream DNS is slow",
        "targetNodes": [
          "dns-resolver"
        ],
        "faultType": "latency",
        "severity": 3,
        "expectedBehavior": "Crawl rate drops dramatically. URL frontier queue grows.",
        "mitigationSteps": [
          "Multiple DNS resolvers",
          "Extended DNS cache TTL",
          "Fallback to IP-based crawling"
        ]
      },
      {
        "id": "cs-spider-trap",
        "name": "Spider Trap Detection Failure",
        "description": "Crawler stuck in infinite URL generation on a malicious site",
        "targetNodes": [
          "crawler-workers"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Crawler resources consumed by single domain. Other domains starved.",
        "mitigationSteps": [
          "Per-domain crawl limits",
          "URL depth limiting",
          "Duplicate URL detection"
        ]
      },
      {
        "id": "cs-storage-full",
        "name": "Content Storage Full",
        "description": "Crawled content storage reaches capacity",
        "targetNodes": [
          "content-store"
        ],
        "faultType": "resource-exhaustion",
        "severity": 4,
        "expectedBehavior": "New pages cannot be stored. Crawling pauses.",
        "mitigationSteps": [
          "Evict stale content",
          "Expand storage",
          "Prioritize high-value pages"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 5000,
        "bottleneckNode": "dns-resolver",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 10000,
        "bottleneckNode": "crawler-workers",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-web-crawler-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "dns-resolver"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-web-crawler-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "content-store"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-web-crawler-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "dns-resolver"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
