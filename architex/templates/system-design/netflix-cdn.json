  "learnSteps": [
    {
      "title": "Adaptive Bitrate Streaming (ABR)",
      "description": "Videos are transcoded into multiple bitrate/resolution variants (240p to 4K). The client player measures network bandwidth in real-time and switches between quality levels seamlessly. Content is chunked into 2-4 second segments, each available at every bitrate. The manifest file (DASH/HLS) lists all available variants.",
      "highlightNodes": ["web-client", "cdn"],
      "highlightEdges": ["e-client-cdn"]
    },
    {
      "title": "CDN Edge Caching & Open Connect",
      "description": "Netflix deploys edge servers (Open Connect Appliances) directly inside ISP networks. Popular content is pre-positioned during off-peak hours. With a 95% cache hit rate across 200+ locations, most video bytes never leave the local ISP network. Cache misses fall back to regional or origin S3 storage.",
      "highlightNodes": ["cdn", "object-storage"],
      "highlightEdges": ["e-client-cdn", "e-cdn-storage"]
    },
    {
      "title": "Content Pipeline & Metadata",
      "description": "The Content Service manages the catalog, recommendations, and playback sessions via the API Gateway. Metadata (titles, thumbnails, subtitles) is cached in Redis with a 92% hit rate. The API path is separate from the video streaming path to optimize each independently.",
      "highlightNodes": ["content-service", "cache", "database"],
      "highlightEdges": ["e-content-cache", "e-content-db", "e-cache-db"]
    },
    {
      "title": "Global Content Delivery Architecture",
      "description": "Two data paths: (1) API calls for browse/search/recommendations go through API Gateway to Load Balancer to Content Service. (2) Video streaming goes directly from Client to nearest CDN edge. This separation allows API servers to scale independently from video delivery. Object Storage holds the master copies of all transcoded content.",
      "highlightNodes": ["api-gw", "load-balancer", "content-service", "object-storage"],
      "highlightEdges": ["e-client-gw", "e-gw-lb", "e-lb-content", "e-content-storage"]
    }
  ]
