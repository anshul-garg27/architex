  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-apns-outage",
        "name": "APNS Provider Outage",
        "description": "Apple Push Notification service is down",
        "targetNodes": [
          "push-provider"
        ],
        "faultType": "crash",
        "severity": 3,
        "expectedBehavior": "iOS push notifications fail. Android unaffected. Queued for retry.",
        "mitigationSteps": [
          "Queue failed pushes for retry",
          "Monitor APNS status",
          "Fallback to SMS for critical notifications"
        ]
      },
      {
        "id": "cs-notification-flood",
        "name": "Notification Storm",
        "description": "System event triggers notifications to all 10M users",
        "targetNodes": [
          "notification-service",
          "push-provider"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Notification delivery delayed. Provider rate limits hit.",
        "mitigationSteps": [
          "Rate-limit per provider",
          "Batch notifications",
          "Priority queue for transactional"
        ]
      },
      {
        "id": "cs-dedup-failure",
        "name": "Duplicate Notification Bug",
        "description": "Deduplication service fails, sending same notification multiple times",
        "targetNodes": [
          "dedup-service"
        ],
        "faultType": "error",
        "severity": 2,
        "expectedBehavior": "Users receive duplicate push notifications. User experience degraded.",
        "mitigationSteps": [
          "Client-side dedup by notification ID",
          "Fix dedup service",
          "Apology notification if widespread"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 25000,
        "bottleneckNode": "push-provider",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "notification-service",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-notification-system-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "push-provider"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-notification-system-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "dedup-service"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-notification-system-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "push-provider"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
