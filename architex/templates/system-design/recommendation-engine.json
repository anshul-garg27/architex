  "learnSteps": [
    {
      "title": "Real-Time Recommendation Serving",
      "description": "When a user opens the app, the Recommendation API fetches pre-computed user embeddings from Redis (feature cache) and sends them to the ML Model Server via gRPC. The model performs approximate nearest neighbor (ANN) search against item embeddings to find the top-K most relevant items in ~15ms. Results are personalized by combining collaborative filtering scores with content-based features.",
      "highlightNodes": ["client", "lb", "app-server", "ml-inference"],
      "highlightEdges": ["e-client-lb", "e-lb-app", "e-app-ml"]
    },
    {
      "title": "Feature Store and Caching",
      "description": "The Feature Cache (Redis) stores pre-computed user profiles, item embeddings, and interaction features. User features include viewing history, genre preferences, and recency-weighted ratings. Item features include popularity scores, freshness, and content tags. With 128GB Redis and 95% cache hit rate, feature lookups add only 1ms to the inference path. Cache misses fall back to Cassandra.",
      "highlightNodes": ["feature-cache", "ml-inference", "database"],
      "highlightEdges": ["e-app-cache", "e-ml-cache", "e-app-db"]
    },
    {
      "title": "Event Collection and Feedback Loop",
      "description": "Every user interaction (view, click, watch duration, skip, rating) is published to Kafka as an event. These events serve dual purposes: real-time feature updates (streaming consumer updates Redis) and batch training data (consumed by Spark). This closed feedback loop ensures the model continuously improves. Kafka retains 30 days of events for retraining and A/B test analysis.",
      "highlightNodes": ["app-server", "mq", "batch-processor"],
      "highlightEdges": ["e-app-mq", "e-mq-batch"]
    },
    {
      "title": "Offline Model Retraining Pipeline",
      "description": "The Batch Processor (Spark) runs nightly, consuming historical interaction data from Kafka and Cassandra. It retrains the collaborative filtering model using matrix factorization (ALS) or deep learning. New embeddings are written back to Redis and the updated model is deployed to the ML Server via blue-green deployment. A/B testing compares new model performance against the current production model before full rollout.",
      "highlightNodes": ["batch-processor", "mq", "ml-inference"],
      "highlightEdges": ["e-mq-batch"]
    }
  ]
}
