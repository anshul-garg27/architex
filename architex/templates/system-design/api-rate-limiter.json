  "learnSteps": [
    {
      "title": "Token Bucket Algorithm in Redis",
      "description": "Each API client has a Redis key storing their token count and last refill timestamp. On each request, a Lua script atomically: (1) calculates tokens to add since last refill, (2) checks if tokens >= 1, (3) decrements the counter. The Lua script runs as a single Redis command, avoiding race conditions. A 429 response is returned when tokens are exhausted.",
      "highlightNodes": [
        "app-server",
        "cache"
      ],
      "highlightEdges": [
        "e-app-cache"
      ]
    },
    {
      "title": "Multi-Tier Rate Limiting",
      "description": "The system enforces limits at multiple granularities: per-second burst limit (e.g., 100 req/s), per-minute sustained limit (e.g., 1000 req/min), and per-day quota (e.g., 100K req/day). Each tier has its own Redis key with an appropriate TTL. The request is rejected if ANY tier is exceeded. Rules are stored in PostgreSQL and cached locally for fast evaluation.",
      "highlightNodes": [
        "cache",
        "database"
      ],
      "highlightEdges": [
        "e-app-cache",
        "e-app-db"
      ]
    },
    {
      "title": "Distributed Counter Consistency",
      "description": "With 10 app server instances behind a load balancer, all rate limit checks go to the same Redis cluster. Redis ensures atomic counter operations across all instances. For even higher availability, a local in-memory counter provides approximate rate limiting if Redis is unreachable (graceful degradation). The slight over-allowance is acceptable vs. blocking all traffic.",
      "highlightNodes": [
        "lb",
        "app-server",
        "cache"
      ],
      "highlightEdges": [
        "e-lb-app",
        "e-app-cache"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-counter-desync",
        "name": "Rate Counter Desync",
        "description": "Redis counter diverges across replicas",
        "targetNodes": [
          "redis-counter"
        ],
        "faultType": "data-corruption",
        "severity": 3,
        "expectedBehavior": "Some requests bypass rate limit, others are incorrectly throttled",
        "mitigationSteps": [
          "Sync counters from primary",
          "Use sliding window log as backup"
        ]
      },
      {
        "id": "cs-redis-crash",
        "name": "Redis Counter Store Crash",
        "description": "Rate limit counter store goes down",
        "targetNodes": [
          "redis-counter"
        ],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "All requests allowed through (fail-open) or all blocked (fail-closed)",
        "mitigationSteps": [
          "Failover to standby Redis",
          "Local in-memory fallback counters"
        ]
      },
      {
        "id": "cs-thundering-herd",
        "name": "Window Reset Thundering Herd",
        "description": "All rate limit windows reset simultaneously",
        "targetNodes": [
          "rate-limiter-svc"
        ],
        "faultType": "resource-exhaustion",
        "severity": 2,
        "expectedBehavior": "Brief spike in allowed requests at window boundary",
        "mitigationSteps": [
          "Sliding window instead of fixed window",
          "Jitter on window boundaries"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "redis-counter",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 100000,
        "bottleneckNode": "redis-counter",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-api-rate-limiter-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "redis-counter"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-api-rate-limiter-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "rate-limiter-svc"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-api-rate-limiter-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "redis-counter"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
