  "learnSteps": [
    {
      "title": "Command Handling and Event Generation",
      "description": "Write operations arrive as commands (e.g., PlaceOrder, UpdateInventory) routed to the Command Service. It loads the aggregate's current state by replaying events from the Event Store, validates the command against business rules, and appends new events (OrderPlaced, InventoryUpdated). Events are immutable facts -- the append-only Event Store never updates or deletes. Optimistic concurrency uses aggregate version numbers to prevent write conflicts.",
      "highlightNodes": ["client", "api-gw", "command-service", "event-store"],
      "highlightEdges": ["e-client-gw", "e-gw-command", "e-command-store"]
    },
    {
      "title": "Event Publication and Transactional Outbox",
      "description": "After persisting events, the Command Service publishes them to Kafka using the transactional outbox pattern: events are written to an outbox table in the same DB transaction as the event store, then a CDC connector (Debezium) streams them to Kafka. This guarantees no events are lost even if the service crashes after the DB write. Kafka retains 90 days of events for full system replay.",
      "highlightNodes": ["command-service", "event-store", "event-bus"],
      "highlightEdges": ["e-command-store", "e-command-bus"]
    },
    {
      "title": "Read Model Projection",
      "description": "The Read Service consumes events from Kafka and builds denormalized read models optimized for specific queries (e.g., a materialized view of order summaries, a user's activity feed). These projections are written to a separate Read Model DB and cached in Redis. Because read and write models are separate, each can be optimized independently -- the write side for consistency, the read side for query performance.",
      "highlightNodes": ["event-bus", "read-service", "read-cache", "read-db"],
      "highlightEdges": ["e-bus-read", "e-read-cache", "e-read-db"]
    },
    {
      "title": "Eventual Consistency and Event Replay",
      "description": "Reads are eventually consistent: there is a small delay (typically 50-200ms) between a command being accepted and the read model being updated. The API Gateway routes writes to the Command Service and reads to the Read Service. If a read model becomes corrupted or a new projection is needed, events can be replayed from the Event Store from any point in time to rebuild the read model from scratch. Snapshots every N events optimize aggregate loading.",
      "highlightNodes": ["api-gw", "command-service", "read-service"],
      "highlightEdges": ["e-gw-command", "e-gw-read", "e-bus-read"]
    }
  ]
}
