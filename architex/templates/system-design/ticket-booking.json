  "learnSteps": [
    {
      "title": "Temporary Seat Locking with Redis TTL",
      "description": "When a user selects seats, the Booking Service acquires a distributed lock in Redis using SET NX with a 10-minute TTL. This temporarily reserves the seats while the user completes payment. If payment fails or times out, the TTL auto-releases the seats — no manual cleanup needed. This prevents overselling during flash sales.",
      "highlightNodes": ["app-server", "cache"],
      "highlightEdges": ["e-app-cache"]
    },
    {
      "title": "Flash Sale Concurrency Control",
      "description": "During high-demand events (concert launches), hundreds of thousands of users compete for limited seats. The Load Balancer distributes traffic across 20+ app instances. Redis handles the seat-locking hotspot. PostgreSQL uses row-level locking on the final commit. A virtual waiting room (queue) can throttle inbound requests to prevent system overload.",
      "highlightNodes": ["lb", "app-server", "cache"],
      "highlightEdges": ["e-client-lb", "e-lb-app", "e-app-cache"]
    },
    {
      "title": "Asynchronous Payment Processing",
      "description": "After seats are locked, a payment job is published to Kafka. The Payment Worker processes it asynchronously — calling Stripe, handling 3D-Secure flows, and retrying on transient failures. On success, the booking is confirmed in PostgreSQL and the Redis lock is released. On failure, seats are automatically freed for others.",
      "highlightNodes": ["mq", "payment-worker", "third-party"],
      "highlightEdges": ["e-app-mq", "e-mq-worker", "e-worker-stripe"]
    },
    {
      "title": "Consistency Between Lock and Booking State",
      "description": "The system must handle the edge case where payment succeeds but the DB write fails (or vice versa). The Payment Worker uses an outbox pattern: it writes the booking confirmation and a 'payment succeeded' event to PostgreSQL in a single transaction, then a relay publishes the event. This ensures exactly-once semantics between payment and booking state.",
      "highlightNodes": ["payment-worker", "database"],
      "highlightEdges": ["e-worker-db", "e-worker-stripe"]
    }
  ]
