  "learnSteps": [
    {
      "title": "Fanout on Write (Push Model)",
      "description": "When a user publishes a post, the Fanout Worker pushes the post ID into every follower's feed list in Redis. For a user with 1,000 followers, this means 1,000 Redis writes. This pre-computes feeds so reads are instant (O(1) cache lookup). The trade-off: write amplification is high for users with millions of followers (celebrities).",
      "highlightNodes": ["mq", "fanout-worker", "cache"],
      "highlightEdges": ["e-mq-fanout", "e-fanout-cache"]
    },
    {
      "title": "Hybrid Fanout Strategy",
      "description": "For celebrity users (1M+ followers), fanout on write is too expensive. Instead, the system uses fanout on read for celebrities: when a user loads their feed, the Feed Service merges their pre-computed feed (from Redis) with recent posts from celebrities they follow (queried from MongoDB at read time). This hybrid approach caps write amplification.",
      "highlightNodes": ["app-server", "cache", "document-db"],
      "highlightEdges": ["e-app-cache", "e-ml-docdb"]
    },
    {
      "title": "ML-Based Feed Ranking",
      "description": "The raw feed (chronological post IDs) is passed to the Feed Ranking Model. It scores each post using signals: user affinity, post engagement (likes, comments), content type, recency, and creator quality. The model reorders the feed to maximize engagement. A/B testing different ranking models is done via feature flags.",
      "highlightNodes": ["app-server", "ml-ranker"],
      "highlightEdges": ["e-app-ml"]
    },
    {
      "title": "Feed Cache and Pagination",
      "description": "Each user's feed is a Redis sorted set (score = timestamp or ranking score). The Feed Service reads the top N items with ZREVRANGE for the first page and cursor-based pagination for subsequent pages. The cache holds the latest ~500 posts per user. Stale feeds (inactive users) are evicted via volatile-lru. On cache miss, the feed is regenerated from the social graph DB.",
      "highlightNodes": ["cache", "database", "app-server"],
      "highlightEdges": ["e-app-cache", "e-app-db"]
    }
  ]
}
