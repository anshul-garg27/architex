  "learnSteps": [
    {
      "title": "Workflow Definition and Scheduling",
      "description": "Clients submit workflow definitions (DAGs of tasks) or trigger existing workflows via the API. The Workflow Service parses the DAG, validates dependencies, creates a workflow execution record in PostgreSQL, and schedules the first set of ready tasks (those with no unmet dependencies) by publishing them to Kafka. Cron-triggered workflows use a scheduler that polls for due executions.",
      "highlightNodes": ["client", "api-gw", "workflow-service", "database"],
      "highlightEdges": ["e-client-gw", "e-gw-workflow", "e-workflow-db"]
    },
    {
      "title": "Durable Task Execution",
      "description": "Workers pull tasks from Kafka, execute the associated logic (HTTP calls, data transforms, shell commands), and report results back. Each task heartbeats to indicate liveness. If a worker crashes, the task is re-delivered after a visibility timeout. Task inputs/outputs are persisted in PostgreSQL, enabling the Workflow Service to resume from exactly where it left off after any failure.",
      "highlightNodes": ["mq", "worker-pool", "database"],
      "highlightEdges": ["e-mq-workers", "e-workers-db"]
    },
    {
      "title": "DAG Progression and Branching",
      "description": "When a task completes, the Workflow Service evaluates the DAG to determine which downstream tasks are now ready. It supports conditional branches (if/else), parallel fan-out, fan-in (wait for all), and retry with exponential backoff. The entire workflow state machine is transactionally updated in PostgreSQL, ensuring consistency even under concurrent task completions.",
      "highlightNodes": ["workflow-service", "mq", "database"],
      "highlightEdges": ["e-workflow-mq", "e-workflow-db"]
    },
    {
      "title": "Artifact Management and Observability",
      "description": "Large task outputs (data files, reports, model artifacts) are stored in S3 with references in PostgreSQL. The Workflow Service provides APIs to query execution history, task logs, and DAG visualizations. Failed workflows can be retried from the point of failure rather than from scratch, saving compute. Metrics (task duration, failure rates, queue depth) drive auto-scaling decisions for the worker pool.",
      "highlightNodes": ["worker-pool", "storage", "workflow-service"],
      "highlightEdges": ["e-workers-storage", "e-workflow-db"]
    }
  ]
}
