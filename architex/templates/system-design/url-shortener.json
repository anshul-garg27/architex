  "learnSteps": [
    {
      "title": "Key Generation Strategy",
      "description": "The URL Service generates unique short keys using Base62 encoding of an auto-incrementing ID or a pre-generated key pool. A 7-character Base62 key gives ~3.5 trillion unique URLs. Using a KGS (Key Generation Service) avoids collisions under high concurrency.",
      "highlightNodes": [
        "web-server"
      ],
      "highlightEdges": []
    },
    {
      "title": "Cache-Aside Pattern",
      "description": "On a redirect request (GET /{shortKey}), the service first checks Redis. With an 85% cache hit rate, most reads never touch the database. On a cache miss, the service queries PostgreSQL, caches the result, then redirects. This is the cache-aside (lazy-loading) pattern.",
      "highlightNodes": [
        "cache",
        "database"
      ],
      "highlightEdges": [
        "e-server-cache",
        "e-cache-db"
      ]
    },
    {
      "title": "301 vs 302 Redirect Flow",
      "description": "The CDN layer can cache 301 (permanent) redirects at edge locations, reducing load on origin servers. However, 302 (temporary) redirects allow analytics tracking per click. The trade-off is between performance (301 + CDN) and analytics granularity (302 + origin).",
      "highlightNodes": [
        "cdn",
        "web-client"
      ],
      "highlightEdges": [
        "e-server-cdn",
        "e-client-gw"
      ]
    },
    {
      "title": "Scaling for Read-Heavy Workload",
      "description": "URL shorteners are extremely read-heavy (100:1 read:write). Scaling strategy: multiple read replicas on PostgreSQL, a large Redis cluster for hot URLs, and CDN caching for the most popular links. The API Gateway handles rate limiting to protect against abuse.",
      "highlightNodes": [
        "api-gw",
        "cache",
        "database"
      ],
      "highlightEdges": [
        "e-gw-server",
        "e-server-cache",
        "e-server-db"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-cache-failure",
        "name": "Redis Cache Failure",
        "description": "Complete Redis failure forcing all reads to hit database",
        "targetNodes": [
          "cache"
        ],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "Read latency increases 10x. DB connection pool saturates. Error rate spikes before circuit breaker activates.",
        "mitigationSteps": [
          "Circuit breaker routes to DB directly",
          "Auto-failover to Redis standby",
          "Gradually warm cache"
        ]
      },
      {
        "id": "cs-db-failover",
        "name": "Database Failover",
        "description": "Primary PostgreSQL crashes triggering replica promotion",
        "targetNodes": [
          "database"
        ],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "Writes fail for 15-30s during failover. Reads served from cache unaffected.",
        "mitigationSteps": [
          "Automatic replica promotion",
          "Application retries with backoff",
          "Verify data consistency post-failover"
        ]
      },
      {
        "id": "cs-cdn-stampede",
        "name": "CDN Cache Stampede",
        "description": "Mass CDN cache eviction causes origin overload",
        "targetNodes": [
          "cdn",
          "web-server"
        ],
        "faultType": "resource-exhaustion",
        "severity": 3,
        "expectedBehavior": "Origin receives 10x traffic. Rate limiting activates.",
        "mitigationSteps": [
          "Request coalescing at CDN",
          "Stale-while-revalidate headers",
          "Auto-scale web servers"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 5000,
        "bottleneckNode": "database",
        "metric": "connections",
        "description": "PostgreSQL connection pool saturates",
        "resolution": "Add read replicas and increase pool size"
      },
      {
        "rpsThreshold": 10000,
        "bottleneckNode": "cache",
        "metric": "memory",
        "description": "Redis memory pressure increases eviction rate",
        "resolution": "Add shards, increase memory"
      },
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "api-gw",
        "metric": "cpu",
        "description": "API gateway CPU saturates from TLS termination",
        "resolution": "Horizontal scale, offload TLS to CDN"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-hot-keys",
        "title": "Hot Key Concentration",
        "description": "Viral URLs create hot keys in Redis",
        "affectedNodes": [
          "cache"
        ],
        "likelihood": 4,
        "impact": 3,
        "mitigation": "Local cache, CDN pinning for viral content"
      },
      {
        "id": "ei-key-collision",
        "title": "Key Generation Collision",
        "description": "Base62 key collision under high write load",
        "affectedNodes": [
          "web-server",
          "database"
        ],
        "likelihood": 2,
        "impact": 3,
        "mitigation": "Pre-generated key pool or collision retry"
      },
      {
        "id": "ei-abuse",
        "title": "Malicious URL Abuse",
        "description": "Service used for phishing links",
        "affectedNodes": [
          "web-server"
        ],
        "likelihood": 5,
        "impact": 4,
        "mitigation": "URL scanning, rate limiting per API key"
      }
    ],
