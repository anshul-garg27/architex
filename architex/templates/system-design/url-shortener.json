  "rationale": {
    "decisions": [
      {
        "title": "Cache-Aside Pattern",
        "context": "Read-heavy workload (100:1 read/write)",
        "decision": "Check cache first, fallback to DB on miss",
        "consequences": [
          "85% cache hit rate",
          "DB handles only 15% of reads"
        ]
      }
    ],
    "tradeoffs": [
      {
        "dimension": "Consistency vs Performance",
        "choice": "Performance",
        "benefit": "Sub-ms reads from cache",
        "cost": "Brief staleness window on updates"
      }
    ],
    "alternatives": [
      {
        "name": "Write-Through Cache",
        "description": "Update cache on every write",
        "prosVsCons": "Lower miss rate but higher write latency",
        "whyNotChosen": "Write path is not latency-sensitive for URL shortener"
      }
    ]
  }
