  "learnSteps": [
    {
      "title": "WebSocket Connection Management",
      "description": "Each mobile client maintains a persistent WebSocket connection through the Load Balancer to a WebSocket Gateway. The gateway maps userId to connectionId in Redis, enabling O(1) message routing. With least-connections balancing, each gateway handles up to 500K concurrent connections. Heartbeats detect stale connections.",
      "highlightNodes": [
        "mobile-client",
        "load-balancer",
        "ws-gateway"
      ],
      "highlightEdges": [
        "e-client-lb",
        "e-lb-ws"
      ]
    },
    {
      "title": "Message Ordering & Delivery",
      "description": "Messages are published to Kafka partitioned by conversationId, guaranteeing per-conversation ordering. The Chat Service consumes messages and writes to Cassandra (partition key = chatId, clustering key = timestamp). Each message gets a server-assigned monotonic sequence number for gap detection.",
      "highlightNodes": [
        "ws-gateway",
        "message-queue",
        "chat-service"
      ],
      "highlightEdges": [
        "e-ws-queue",
        "e-queue-chat",
        "e-chat-db"
      ]
    },
    {
      "title": "Offline Message Delivery",
      "description": "When a recipient is offline (no WebSocket connection in Redis), the Chat Service stores the message in Cassandra with a 'pending' status. When the user reconnects, the gateway queries for pending messages since the client's last-seen sequence number and pushes them in order. Read receipts update message status asynchronously via Kafka.",
      "highlightNodes": [
        "cache",
        "database",
        "chat-service"
      ],
      "highlightEdges": [
        "e-chat-cache",
        "e-chat-db"
      ]
    },
    {
      "title": "Media Message Pipeline",
      "description": "Images, videos, and documents are uploaded directly to S3 via a pre-signed URL. The Chat Service stores only the media reference (URL + metadata) in the message body. Kafka triggers async processing (thumbnail generation, virus scanning). Clients download media lazily, reducing bandwidth for inactive chats.",
      "highlightNodes": [
        "object-storage",
        "message-queue"
      ],
      "highlightEdges": [
        "e-chat-storage",
        "e-queue-storage"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-ws-disconnect",
        "name": "WebSocket Mass Disconnect",
        "description": "Load balancer config change disconnects all WebSocket connections",
        "targetNodes": [
          "ws-gateway"
        ],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "All users disconnect. Messages queued for offline delivery. Reconnection storm.",
        "mitigationSteps": [
          "Clients auto-reconnect with jitter",
          "Message queue buffers during reconnection",
          "Scale gateway for reconnection surge"
        ]
      },
      {
        "id": "cs-message-db-latency",
        "name": "Message DB Latency Spike",
        "description": "Cassandra compaction causes read latency spike",
        "targetNodes": [
          "message-store"
        ],
        "faultType": "latency",
        "severity": 3,
        "expectedBehavior": "Message history loading slow. Real-time delivery unaffected (via WebSocket).",
        "mitigationSteps": [
          "Tune compaction schedule",
          "Add Cassandra nodes",
          "Cache recent messages in Redis"
        ]
      },
      {
        "id": "cs-presence-stale",
        "name": "Presence Data Stale",
        "description": "Presence heartbeat processing falls behind",
        "targetNodes": [
          "presence-service"
        ],
        "faultType": "latency",
        "severity": 2,
        "expectedBehavior": "Users shown as online when actually offline. No message delivery impact.",
        "mitigationSteps": [
          "Scale presence workers",
          "Increase heartbeat timeout tolerance",
          "Client-side presence fallback"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "ws-gateway",
