  "learnSteps": [
    {
      "title": "Stock Level Reads with Cache-Aside",
      "description": "Product listing pages need sub-10ms stock level checks. The Inventory Service first checks Redis for stock counts (98% hit rate). On cache miss, it queries PostgreSQL and populates Redis with a 5-minute TTL. Stock levels in Redis are approximate for reads (eventual consistency is acceptable for display), but writes use a different path to ensure accuracy. This pattern handles flash sale traffic spikes.",
      "highlightNodes": ["client", "api-gw", "app-server", "stock-cache"],
      "highlightEdges": ["e-client-gw", "e-gw-app", "e-app-cache"]
    },
    {
      "title": "Atomic Stock Reservation (Oversell Prevention)",
      "description": "When a user adds to cart or checks out, the Inventory Service uses Redis DECRBY atomically to reserve stock. If the result is negative, the reservation fails immediately (no oversell). The service then publishes a reservation event to Kafka. This two-phase approach uses Redis for speed and atomicity, while PostgreSQL maintains the source of truth. The noeviction policy ensures stock counters are never lost.",
      "highlightNodes": ["app-server", "stock-cache", "mq"],
      "highlightEdges": ["e-app-cache", "e-app-mq"]
    },
    {
      "title": "Reservation Confirmation and Expiry",
      "description": "The Reservation Worker consumes events from Kafka and confirms the reservation in PostgreSQL using a serializable transaction (UPDATE stock SET available = available - quantity WHERE available >= quantity). If the DB transaction succeeds, the reservation is confirmed. Unconfirmed reservations expire after 15 minutes, and the worker releases the Redis counter via INCRBY. This prevents cart-holding attacks.",
      "highlightNodes": ["mq", "reservation-worker", "database"],
      "highlightEdges": ["e-mq-worker", "e-worker-db"]
    },
    {
      "title": "Cache-Database Consistency",
      "description": "After DB writes (order confirmed, stock replenished, reservation expired), the Worker invalidates the Redis key rather than updating it, avoiding stale cache issues. The next read triggers a cache-aside refill from PostgreSQL. For hot products during flash sales, Redis counters are treated as authoritative and periodically synced to PostgreSQL via batch reconciliation, trading consistency for throughput.",
      "highlightNodes": ["reservation-worker", "stock-cache", "database"],
      "highlightEdges": ["e-worker-db", "e-app-cache"]
    }
  ]
}
