  "learnSteps": [
    {
      "title": "Login Flow and Token Issuance",
      "description": "The client sends credentials (email + password) over HTTPS to the Auth Server via the Load Balancer. The Auth Server queries PostgreSQL for the user record, verifies the password against bcrypt/argon2 hash, checks MFA status, and issues a signed JWT access token (short-lived, 15 min) plus a refresh token (long-lived, 7 days). The refresh token is stored in Redis for revocation capability.",
      "highlightNodes": ["client", "lb", "auth-server", "database"],
      "highlightEdges": ["e-client-lb", "e-lb-auth", "e-auth-db"]
    },
    {
      "title": "Session Management with Redis",
      "description": "Active sessions are stored in Redis with a TTL matching the refresh token expiry. On each API request, downstream services validate the JWT signature locally (no network call). When a token refresh is needed, the Auth Server checks Redis to ensure the session hasn't been revoked. This design enables instant logout (delete from Redis) while keeping token validation fast and distributed.",
      "highlightNodes": ["auth-server", "cache"],
      "highlightEdges": ["e-auth-cache"]
    },
    {
      "title": "Async Email Notifications",
      "description": "Security-sensitive events (new login, password change, MFA enrollment) trigger email notifications. The Auth Server publishes events to SQS, and Email Workers consume and send via SES/SendGrid. This decoupling ensures login latency isn't affected by email delivery. Workers retry transient failures with exponential backoff.",
      "highlightNodes": ["auth-server", "mq", "email-worker"],
      "highlightEdges": ["e-auth-mq", "e-mq-worker"]
    },
    {
      "title": "Security Hardening",
      "description": "The system implements defense-in-depth: rate limiting at the LB (brute force protection), bcrypt with high cost factor for password hashing, account lockout after N failed attempts (tracked in Redis), TOTP/WebAuthn for MFA, and refresh token rotation on each use. PostgreSQL stores an audit log of all authentication events for compliance and incident response.",
      "highlightNodes": ["lb", "auth-server", "cache", "database"],
      "highlightEdges": ["e-client-lb", "e-auth-cache", "e-auth-db"]
    }
  ]
}
