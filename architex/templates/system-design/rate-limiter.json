  "learnSteps": [
    {
      "title": "Token Bucket Algorithm",
      "description": "Each client gets a bucket with N tokens (e.g., 1000). Each request consumes one token. Tokens refill at a fixed rate (e.g., 100/sec). If the bucket is empty, the request is rejected with HTTP 429. Redis stores the token count and last-refill timestamp per client key. A Lua script atomically checks-and-decrements to avoid race conditions.",
      "highlightNodes": [
        "rate-limiter-svc",
        "cache"
      ],
      "highlightEdges": [
        "e-rl-cache"
      ]
    },
    {
      "title": "Sliding Window Counter",
      "description": "An alternative to token bucket: count requests in the current window and a weighted portion of the previous window. For a 1-minute window at 30 seconds in, the count is: (current_count) + (previous_count * 0.5). This smooths out bursts at window boundaries. Redis sorted sets with timestamps enable precise sliding windows.",
      "highlightNodes": [
        "rate-limiter-svc",
        "cache"
      ],
      "highlightEdges": [
        "e-rl-cache"
      ]
    },
    {
      "title": "Distributed Rate Limiting",
      "description": "With multiple Rate Limiter instances, Redis acts as the shared state. Each instance runs an atomic Lua script: EVALSHA to check and update the counter. Rate limit rules (per-client, per-endpoint, global) are stored in PostgreSQL and cached. The API Gateway extracts the client identifier (API key, IP, user ID) and routes to the limiter.",
      "highlightNodes": [
        "api-gw",
        "rate-limiter-svc",
        "cache",
        "database"
      ],
      "highlightEdges": [
        "e-gw-rl",
        "e-rl-cache",
        "e-server-db"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-token-bucket-overflow",
        "name": "Token Bucket Overflow",
        "description": "Token bucket refill rate misconfigured, allowing burst beyond limits",
        "targetNodes": [
          "rate-limiter"
        ],
        "faultType": "error",
        "severity": 3,
        "expectedBehavior": "Downstream services receive more traffic than expected.",
        "mitigationSteps": [
          "Validate bucket config on startup",
          "Secondary rate limit at downstream",
          "Config change requires approval"
        ]
      },
      {
        "id": "cs-distributed-counter-lag",
        "name": "Distributed Counter Lag",
        "description": "Counter synchronization lag between rate limiter nodes",
        "targetNodes": [
          "rate-limiter",
          "redis-store"
        ],
        "faultType": "latency",
        "severity": 2,
        "expectedBehavior": "Brief over-admission at window boundaries",
        "mitigationSteps": [
          "Sliding window algorithm",
          "Local + global counter hybrid"
        ]
      },
      {
        "id": "cs-redis-store-crash",
        "name": "Counter Store Crash",
        "description": "Redis backing store crashes",
        "targetNodes": [
          "redis-store"
        ],
        "faultType": "crash",
        "severity": 4,
        "expectedBehavior": "Rate limiting disabled or all traffic blocked based on fail policy",
        "mitigationSteps": [
          "Local in-memory counters as fallback",
          "Redis failover",
          "Configurable fail-open vs fail-closed"
        ]
      }
    ],
