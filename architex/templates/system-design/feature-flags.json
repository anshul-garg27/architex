  "learnSteps": [
    {
      "title": "Flag Evaluation Hot Path",
      "description": "Application SDKs call the Flag Evaluation Service on every feature check. The service reads flag definitions from Redis (99% cache hit rate, sub-millisecond). Flag evaluation applies targeting rules (user segment, percentage rollout, environment) and returns a boolean or variant. The entire hot path completes in under 5ms to avoid impacting application latency.",
      "highlightNodes": [
        "client",
        "app-server",
        "cache"
      ],
      "highlightEdges": [
        "e-client-app",
        "e-app-cache"
      ]
    },
    {
      "title": "Flag Storage and Versioning",
      "description": "Flag definitions (name, variants, targeting rules, rollout percentage) are stored in PostgreSQL. Each flag change creates a new version, enabling rollback and audit trails. The admin dashboard writes to PostgreSQL, which triggers a change event. On cache miss, the service falls back to the database and populates the cache.",
      "highlightNodes": [
        "database",
        "app-server"
      ],
      "highlightEdges": [
        "e-app-db"
      ]
    },
    {
      "title": "Real-Time Flag Propagation",
      "description": "When a flag is updated in PostgreSQL, a change event is published to Kafka. All Flag Evaluation Service instances and the Redis cache subscribe to this topic. This ensures all nodes converge on the new flag state within seconds, without polling. The propagation pattern is similar to a CDC (Change Data Capture) pipeline.",
      "highlightNodes": [
        "database",
        "mq",
        "cache"
      ],
      "highlightEdges": [
        "e-db-mq",
        "e-mq-cache"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-flag-store-down",
        "name": "Flag Store Unavailable",
        "description": "Feature flag database becomes unreachable",
        "targetNodes": [
          "flag-store"
        ],
        "faultType": "crash",
        "severity": 3,
        "expectedBehavior": "Services use cached flag values. No new flag changes propagate.",
        "mitigationSteps": [
          "Local SDK cache serves stale flags",
          "Fallback to default values",
          "Restore flag store"
        ]
      },
      {
        "id": "cs-bad-rollout",
        "name": "Bad Feature Rollout",
        "description": "Feature flag enabled for 100% causes production incident",
        "targetNodes": [
          "flag-evaluator"
        ],
        "faultType": "error",
        "severity": 4,
        "expectedBehavior": "Feature causes errors for all users. Need immediate kill switch.",
        "mitigationSteps": [
          "Emergency kill switch via flag disable",
          "Automatic rollback on error rate spike",
          "Gradual rollout policy enforcement"
        ]
      },
      {
        "id": "cs-evaluation-latency",
        "name": "Complex Rule Evaluation Spike",
        "description": "Complex targeting rules cause evaluation latency spike",
        "targetNodes": [
          "flag-evaluator"
        ],
        "faultType": "latency",
        "severity": 2,
        "expectedBehavior": "Flag evaluation takes >100ms, adding latency to every request",
        "mitigationSteps": [
          "Cache evaluation results per user segment",
          "Simplify targeting rules",
          "Pre-compute segments"
        ]
      }
    ],
    "bottleneckProgression": [
      {
        "rpsThreshold": 25000,
        "bottleneckNode": "flag-store",
        "metric": "cpu",
        "description": "Primary service CPU saturates",
        "resolution": "Horizontal scaling, optimize hot paths"
      },
      {
        "rpsThreshold": 50000,
        "bottleneckNode": "flag-evaluator",
        "metric": "connections",
        "description": "Connection pool exhaustion on storage tier",
        "resolution": "Add connection pooling, increase limits"
      }
    ],
    "expectedIssues": [
      {
        "id": "ei-feature-flags-1",
        "title": "Peak Traffic Degradation",
        "description": "Service degrades during traffic spikes",
        "affectedNodes": [
          "flag-store"
        ],
        "likelihood": 3,
        "impact": 3,
        "mitigation": "Auto-scaling policies, load shedding"
      },
      {
        "id": "ei-feature-flags-2",
        "title": "Data Consistency Issue",
        "description": "Eventual consistency causes brief stale reads",
        "affectedNodes": [
          "flag-evaluator"
        ],
        "likelihood": 3,
        "impact": 2,
        "mitigation": "Read-your-writes consistency for critical paths"
      },
      {
        "id": "ei-feature-flags-3",
        "title": "Dependency Failure Impact",
        "description": "Upstream dependency failure cascades to this service",
        "affectedNodes": [
          "flag-store"
        ],
        "likelihood": 2,
        "impact": 4,
        "mitigation": "Circuit breaker pattern, graceful degradation"
      }
    ],
