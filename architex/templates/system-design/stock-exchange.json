  "learnSteps": [
    {
      "title": "Order Flow and Risk Validation",
      "description": "Trading clients submit orders (buy/sell, limit/market) through the API Gateway, which performs pre-trade risk checks: margin validation, position limits, and circuit breaker thresholds. Validated orders are forwarded to the Order Service, which assigns a sequence number and publishes to the Order Book Queue. Strict ordering per symbol is maintained via Kafka partition keys.",
      "highlightNodes": ["client", "api-gw", "app-server"],
      "highlightEdges": ["e-client-gw", "e-gw-app", "e-app-mq"]
    },
    {
      "title": "Matching Engine (Price-Time Priority)",
      "description": "The Matching Engine (Flink) consumes orders from Kafka and maintains an in-memory order book per symbol — sorted buy orders (descending price) and sell orders (ascending price). When a buy price >= sell price, a trade executes. This is the price-time priority algorithm. The engine processes millions of matches per second with exactly-once guarantees via Flink checkpointing.",
      "highlightNodes": ["mq", "stream-processor"],
      "highlightEdges": ["e-mq-match"]
    },
    {
      "title": "Trade Settlement and Persistence",
      "description": "Executed trades are written to PostgreSQL (trade records, position updates, P&L) and TimescaleDB (tick-by-tick market data, OHLCV candles). PostgreSQL uses serializable transactions for settlement correctness. TimescaleDB enables efficient time-range queries for charts and analytics. Both writes happen asynchronously from the matching engine's critical path.",
      "highlightNodes": ["stream-processor", "database", "tsdb"],
      "highlightEdges": ["e-match-db", "e-match-tsdb"]
    },
    {
      "title": "Real-Time Market Data Distribution",
      "description": "After each trade, the latest price is pushed to the Redis cache with a 1-second TTL. Trading clients poll or subscribe (via WebSocket) for real-time quotes. The Price Cache serves as a read-optimized layer, handling millions of price lookups per second. TimescaleDB feeds the cache with aggregated price updates, ensuring consistency between tick data and displayed quotes.",
      "highlightNodes": ["cache", "tsdb", "app-server"],
      "highlightEdges": ["e-tsdb-cache", "e-app-cache"]
    }
  ]
}
