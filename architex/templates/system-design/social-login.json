  "learnSteps": [
    {
      "title": "OAuth 2.0 Authorization Code Flow",
      "description": "The client redirects the user to the chosen provider (Google/GitHub). After the user grants consent, the provider redirects back with an authorization code. The client sends this code to the Auth Server, which exchanges it with the provider for an access token and ID token. This server-side exchange prevents token leakage in the browser. The API Gateway rate-limits login attempts to prevent abuse.",
      "highlightNodes": ["client", "api-gw", "auth-server"],
      "highlightEdges": ["e-client-gw", "e-gw-auth"]
    },
    {
      "title": "Token Exchange with Providers",
      "description": "The Auth Server calls the provider's token endpoint with the authorization code, client ID, and client secret. Google returns an ID token (JWT with email, name, picture) plus an access token. GitHub returns an access token, requiring a separate /user API call for profile data. The Auth Server normalizes both responses into a unified user profile format before proceeding with account lookup.",
      "highlightNodes": ["auth-server", "google-api", "github-api"],
      "highlightEdges": ["e-auth-google", "e-auth-github"]
    },
    {
      "title": "Account Linking and Creation",
      "description": "The Auth Server queries PostgreSQL for an existing user matching the provider's email. If found, it links the OAuth identity to the existing account (supports multiple providers per user). If not found, it creates a new user record with the provider profile. The users table stores provider_id + provider_type as a unique constraint. Refresh tokens from providers are encrypted at rest in the DB.",
      "highlightNodes": ["auth-server", "database"],
      "highlightEdges": ["e-auth-db"]
    },
    {
      "title": "Session Management and Caching",
      "description": "After successful authentication, the Auth Server issues its own JWT access token (15 min TTL) and refresh token (7 day TTL). The session is stored in Redis keyed by session ID with the user's profile and permissions. Subsequent API requests validate the JWT signature locally; Redis is only hit for refresh or revocation checks. Logout deletes the Redis entry, instantly invalidating the session across all services.",
      "highlightNodes": ["auth-server", "session-cache"],
      "highlightEdges": ["e-auth-cache"]
    }
  ]
}
