  "learnSteps": [
    {
      "title": "Deterministic User Bucketing",
      "description": "When a user requests an experiment variant, the Assignment Service hashes the user ID + experiment ID using MurmurHash3 to produce a deterministic bucket (0-9999). Each experiment defines bucket ranges per variant (e.g., control=0-4999, treatment=5000-9999 for a 50/50 split). This ensures the same user always sees the same variant without storing per-user state, and different experiments get independent random assignments.",
      "highlightNodes": ["client", "lb", "assignment-service"],
      "highlightEdges": ["e-client-lb", "e-lb-assign"]
    },
    {
      "title": "Assignment Caching and Experiment Configuration",
      "description": "Experiment definitions (name, variants, traffic allocation, targeting rules, start/end dates) are stored in PostgreSQL and cached in Redis with a 95% hit rate. On each request the service checks Redis for the experiment config, falls back to PostgreSQL on miss. Cached assignments mean subsequent variant lookups for the same user complete in under 1ms. The cache is invalidated via a Kafka event when an experiment is updated.",
      "highlightNodes": ["assignment-cache", "experiment-db", "assignment-service"],
      "highlightEdges": ["e-assign-cache", "e-assign-expdb"]
    },
    {
      "title": "Real-Time Event Ingestion",
      "description": "Every user action (page view, click, conversion, purchase) is published to Kafka along with the experiment assignment context (experiment ID, variant, user ID). Kafka's 32 partitions keyed by user ID ensure ordered processing per user. The exactly-once semantics in Flink prevent double-counting conversions. This event stream captures both the assignment moment and all downstream user behavior for causal analysis.",
      "highlightNodes": ["assignment-service", "event-queue", "stream-processor"],
      "highlightEdges": ["e-assign-mq", "e-mq-stream"]
    },
    {
      "title": "Statistical Analysis and Results",
      "description": "Flink aggregates events per experiment-variant pair into ClickHouse: conversion rates, revenue sums, sample sizes, and confidence intervals. The platform runs sequential testing (not just fixed-horizon) to allow early stopping when results are statistically significant. It computes p-values, confidence intervals, and minimum detectable effect (MDE). Guardrail metrics (latency, error rate) are monitored to catch experiments that degrade overall performance.",
      "highlightNodes": ["stream-processor", "analytics-db"],
      "highlightEdges": ["e-mq-stream", "e-stream-analytics"]
    }
  ]
}
