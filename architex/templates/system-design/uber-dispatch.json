  "learnSteps": [
    {
      "title": "Geospatial Matching with S2/H3",
      "description": "The Location Service uses geospatial indexing (Google S2 or Uber H3) to map driver locations to grid cells. Redis stores driver positions with GEOADD/GEORADIUS commands. When a rider requests, the Dispatch Service queries nearby cells for available drivers within expanding radius rings until a match is found.",
      "highlightNodes": ["location-service", "cache"],
      "highlightEdges": ["e-location-cache", "e-dispatch-location"]
    },
    {
      "title": "Surge Pricing & Supply-Demand",
      "description": "The Dispatch Service calculates surge multipliers per H3 cell based on the ratio of ride requests to available drivers. Kafka streams real-time supply/demand events. The pricing algorithm uses a sliding window over recent requests and driver availability to set dynamic multipliers.",
      "highlightNodes": ["dispatch-service", "message-queue"],
      "highlightEdges": ["e-dispatch-kafka", "e-location-kafka"]
    },
    {
      "title": "Trip State Machine",
      "description": "Each trip follows a strict state machine: REQUESTED -> MATCHED -> DRIVER_EN_ROUTE -> ARRIVED -> IN_PROGRESS -> COMPLETED (or CANCELLED at any stage). The Trip DB stores the current state with optimistic locking. All state transitions are published to Kafka for downstream services (billing, analytics, ETA).",
      "highlightNodes": ["dispatch-service", "database", "message-queue"],
      "highlightEdges": ["e-dispatch-db", "e-dispatch-kafka"]
    },
    {
      "title": "Real-Time Location Updates",
      "description": "Drivers send GPS updates every 3-4 seconds via the mobile client. The Location Service writes to Redis with a 30-second TTL (drivers who stop sending are auto-removed). With 98% cache hit rate and 64GB Redis, the system tracks millions of active drivers. Location updates also flow to Kafka for trip ETA and analytics.",
      "highlightNodes": ["mobile-client", "location-service", "cache"],
      "highlightEdges": ["e-client-gw", "e-lb-location", "e-location-cache"]
    }
  ]
}
