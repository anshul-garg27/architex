  "learnSteps": [
    {
      "title": "Inventory Check and Double-Booking Prevention",
      "description": "The Reservation Service checks room availability via Redis cache first (sub-millisecond). On booking, it uses a PostgreSQL row-level lock (SELECT FOR UPDATE) or an optimistic concurrency check (version column) to prevent double-booking the same room for the same dates. This is the critical correctness invariant of the system.",
      "highlightNodes": [
        "app-server",
        "cache",
        "database"
      ],
      "highlightEdges": [
        "e-app-cache",
        "e-app-db"
      ]
    },
    {
      "title": "Idempotent Booking with Reservation ID",
      "description": "The API Gateway assigns a unique idempotency key to each booking request. If a client retries (network timeout, 5xx), the service checks for an existing reservation with that key before creating a new one. This prevents duplicate charges and ghost bookings \u2014 essential for payment-adjacent workflows.",
      "highlightNodes": [
        "api-gw",
        "app-server"
      ],
      "highlightEdges": [
        "e-client-gw",
        "e-gw-app"
      ]
    },
    {
      "title": "Asynchronous Confirmation Notifications",
      "description": "After a successful booking, the Reservation Service publishes a BookingConfirmed event to Kafka. The Notification Worker consumes this event and sends email/SMS confirmations, triggers calendar invites, and notifies the hotel's PMS. Decoupling via the queue means booking latency is unaffected by slow downstream services.",
      "highlightNodes": [
        "mq",
        "notification-worker"
      ],
      "highlightEdges": [
        "e-app-mq",
        "e-mq-worker"
      ]
    },
    {
      "title": "Cache Invalidation for Room Inventory",
      "description": "Room availability in Redis is updated on every booking and cancellation. A short TTL (5 min) ensures stale data self-heals. For flash sales or peak periods, the cache is warmed proactively. The write-through pattern ensures the cache and DB stay consistent for high-traffic inventory queries.",
      "highlightNodes": [
        "cache",
        "database",
        "app-server"
      ],
      "highlightEdges": [
        "e-app-cache",
        "e-app-db"
      ]
    }
  ],
  "simulation": {
    "chaosScenarios": [
      {
        "id": "cs-double-booking",
        "name": "Double Booking Race Condition",
        "description": "Concurrent reservations for last room succeed simultaneously",
        "targetNodes": [
          "reservation-service",
          "inventory-db"
        ],
        "faultType": "data-corruption",
        "severity": 5,
        "expectedBehavior": "Two guests booked for same room. Manual resolution required.",
        "mitigationSteps": [
          "Pessimistic locking on room inventory",
          "Database-level constraints",
          "Overbooking compensation policy"
        ]
      },
      {
        "id": "cs-payment-failure",
        "name": "Payment Gateway Timeout",
        "description": "Payment provider experiences widespread latency",
        "targetNodes": [
          "payment-service"
        ],
        "faultType": "latency",
        "severity": 3,
        "expectedBehavior": "Bookings stuck in pending state. Inventory held but not confirmed.",
        "mitigationSteps": [
          "Reservation hold with TTL",
          "Retry payment async",
          "Alternative payment provider"
        ]
      },
      {
        "id": "cs-search-degraded",
        "name": "Search Index Degraded",
        "description": "Elasticsearch cluster loses a node during peak search",
        "targetNodes": [
          "search-service"
        ],
        "faultType": "crash",
        "severity": 3,
        "expectedBehavior": "Search latency increases. Some search features degraded.",
        "mitigationSteps": [
          "ES replica promotion",
          "Fallback to simpler DB queries",
          "Cached popular searches"
        ]
      }
    ],
